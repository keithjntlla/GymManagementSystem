<UserControl x:Class="GymManagementSystem.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <UserControl.Resources>

        <!-- ── Tab Button ─────────────────────────────────────────── -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="{TemplateBinding Tag}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border x:Name="HighlightBar" Height="3" Background="#ff6b00"
                                    VerticalAlignment="Bottom" Visibility="Collapsed" CornerRadius="1.5"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="HighlightBar" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Summary Card ───────────────────────────────────────── -->
        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Height" Value="180"/>
        </Style>

        <!-- ── Nav Button (Prev/Next) ─────────────────────────────── -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1a1a1c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2a2a2c"/>
                                <Setter Property="BorderBrush" Value="#ff6b00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Icon Button (Refresh) ──────────────────────────────── -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1a1a1c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2a2a2c"/>
                                <Setter Property="BorderBrush" Value="#ff6b00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="0,20,0,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Reports" Foreground="White" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="View and analyze gym performance metrics" Foreground="Gray" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Tab Navigation -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,0">
            <RadioButton Content="Financial"   Tag="💰" IsChecked="True" Style="{StaticResource TabButtonStyle}" Click="TabFinancial_Click"/>
            <RadioButton Content="Attendance"  Tag="📊" Style="{StaticResource TabButtonStyle}" Click="TabAttendance_Click"/>
            <RadioButton Content="Expirations" Tag="⏰" Style="{StaticResource TabButtonStyle}" Click="TabExpirations_Click"/>
        </StackPanel>
        <Separator Grid.Row="1" VerticalAlignment="Bottom" Background="#333"/>

        <!-- ══════════════════════════════════════════════════════════
             FINANCIAL REPORT
             ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="FinancialReportGrid" Grid.Row="2" Grid.RowSpan="2" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filters -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Start Date" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                    <DatePicker x:Name="dpStart" Width="180" Style="{StaticResource ModernDatePicker}"
                                SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                </StackPanel>
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="End Date" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                    <DatePicker x:Name="dpEnd" Width="180" Style="{StaticResource ModernDatePicker}"
                                SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Filter by Plan" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                    <ComboBox x:Name="cbPlanFilter" Width="180" Style="{StaticResource ModernComboBox}"
              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Plans" IsSelected="True"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <!-- Summary Cards -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,30">
                <Border Style="{StaticResource SummaryCardStyle}" Background="#1a3a2a">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#2a4a3a" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="💵" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Total Revenue" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblTotalRevenue" Text="₱0" Foreground="White"
                                   FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Background="#1a2a4a">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#2a3a5a" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Walk-ins (₱90)" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblWalkIns" Text="₱0" Foreground="White"
                                   FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblWalkInsCount" Text="0 transactions" Foreground="Gray"
                                   FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Background="#3a2a1a" Margin="0,0,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#4a3a2a" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Subscriptions" Foreground="LightGray" FontSize="14"/>
                        <TextBlock x:Name="lblSubscriptions" Text="₱0" Foreground="White"
                                   FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblSubscriptionsCount" Text="0 transactions" Foreground="LightGray"
                                   FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Transaction DataGrid -->
            <Border Grid.Row="2" Background="#141416" CornerRadius="15" Padding="10">
                <DataGrid x:Name="dgTransactions" Background="Transparent" BorderThickness="0"
                          Foreground="White" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" RowBackground="Transparent"
                          AlternatingRowBackground="#1a1a1c" GridLinesVisibility="None">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#333"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date"           Binding="{Binding DateOfTransaction}" Width="*"/>
                        <DataGridTextColumn Header="Member Name"    Binding="{Binding MemberName}"        Width="1.5*"/>
                        <DataGridTextColumn Header="Plan"           Binding="{Binding MembershipType}"    Width="*"/>
                        <DataGridTextColumn Header="Amount"         Binding="{Binding AmountPaid, StringFormat=₱\{0:N0\}}" Width="*"/>
                        <DataGridTextColumn Header="Payment Method" Binding="{Binding PaymentMode}"       Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             ATTENDANCE REPORT
             ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="AttendanceReportGrid" Grid.Row="2" Grid.RowSpan="2" Margin="0,20,0,0"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="#141416" CornerRadius="12" Padding="12" Margin="0,0,0,15">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                        <Button x:Name="btnPrevDay" Content="‹" Style="{StaticResource NavButtonStyle}"
                                Click="BtnPrevDay_Click" Margin="0,0,8,0"/>
                        <DatePicker x:Name="dpAttendanceDate" Width="160"
                                    Style="{StaticResource ModernDatePicker}"
                                    SelectedDateChanged="DpAttendanceDate_SelectedDateChanged"/>
                        <Button x:Name="btnNextDay" Content="›" Style="{StaticResource NavButtonStyle}"
                                Click="BtnNextDay_Click" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#1a1a1c" BorderBrush="#333" BorderThickness="1"
                                CornerRadius="8" Padding="8,0" Width="280" Height="36" Margin="0,0,8,0">
                            <DockPanel VerticalAlignment="Center">
                                <TextBlock Text="🔍" FontSize="14" Foreground="Gray"
                                           VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                                <TextBox x:Name="txtAttendanceSearch" Background="Transparent"
                                         BorderThickness="0" Foreground="White" CaretBrush="White"
                                         FontSize="13" VerticalAlignment="Center"
                                         Tag="Search member name or type..."
                                         TextChanged="TxtAttendanceSearch_TextChanged">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                                          Background="Transparent"
                                                                          VerticalAlignment="Center"/>
                                                            <TextBlock Foreground="Gray" FontSize="13"
                                                                       VerticalAlignment="Center"
                                                                       IsHitTestVisible="False"
                                                                       Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=TextBox}}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </DockPanel>
                        </Border>
                        <Button x:Name="btnRefreshAttendance" Style="{StaticResource IconButtonStyle}"
                                Click="BtnRefreshAttendance_Click" ToolTip="Refresh">
                            <TextBlock Text="↺" FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Summary Cards -->
            <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,15">
                <Border Style="{StaticResource SummaryCardStyle}" Background="#1a2a4a" Margin="0,0,8,0">
                    <DockPanel VerticalAlignment="Center">
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                            <TextBlock Text="Total Visitors Today" Foreground="#8899bb" FontSize="13"/>
                            <TextBlock x:Name="lblTotalVisitors" Text="0" Foreground="White"
                                       FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Width="48" Height="48" Background="#2a3a5a" CornerRadius="12"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="👥" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DockPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Background="#3a1e0a" Margin="8,0,0,0">
                    <DockPanel VerticalAlignment="Center">
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                            <TextBlock Text="Peak Hour" Foreground="#bb8866" FontSize="13"/>
                            <TextBlock x:Name="lblPeakHour" Text="--" Foreground="White"
                                       FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Width="48" Height="48" Background="#5a3010" CornerRadius="12"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="📈" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <!-- Attendance DataGrid -->
            <Border Grid.Row="2" Background="#141416" CornerRadius="15" Padding="10">
                <DataGrid x:Name="dgAttendanceReport" Background="Transparent" BorderThickness="0"
                          Foreground="White" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" RowBackground="Transparent"
                          AlternatingRowBackground="#1a1a1c" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#222" RowHeight="52" FontSize="14"
                          HeadersVisibility="Column">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#2a2a2c"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#202022"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="15,0" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time of Entry" Binding="{Binding CheckInTime}"  Width="1.2*"/>
                        <DataGridTextColumn Header="Time Out"      Binding="{Binding CheckOutTime}" Width="1.2*"/>
                        <DataGridTextColumn Header="Member Name"   Binding="{Binding Name}"         Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Membership Type" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="BadgeBorder" CornerRadius="6" Padding="10,4"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Background="#2a2a2c">
                                        <TextBlock x:Name="BadgeText" Text="{Binding MembershipType}"
                                                   FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding MembershipType}" Value="Daily">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#3a2200"/>
                                            <Setter TargetName="BadgeText"   Property="Foreground" Value="#ff9940"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding MembershipType}" Value="Weekly">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#0a2a2a"/>
                                            <Setter TargetName="BadgeText"   Property="Foreground" Value="#30c0b0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding MembershipType}" Value="Half-Month">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#251a3a"/>
                                            <Setter TargetName="BadgeText"   Property="Foreground" Value="#a070f0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding MembershipType}" Value="Monthly">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#0a1a3a"/>
                                            <Setter TargetName="BadgeText"   Property="Foreground" Value="#4090f0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding MembershipType}" Value="Yearly">
                                            <Setter TargetName="BadgeBorder" Property="Background" Value="#0a2a1a"/>
                                            <Setter TargetName="BadgeText"   Property="Foreground" Value="#30c070"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             EXPIRATIONS REPORT
             ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="ExpirationsReportGrid" Grid.Row="2" Grid.RowSpan="2" Margin="0,20,0,0"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter Bar -->
            <Border Grid.Row="0" Background="#141416" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Window Filter -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Expiration Window" Foreground="Gray" FontSize="12" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cbExpirationWindow" Width="220"
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="CbExpirationWindow_SelectionChanged">
                            <ComboBoxItem Content="Expiring Today"           IsSelected="True"/>
                            <ComboBoxItem Content="Expiring within 3 Days"/>
                            <ComboBoxItem Content="Expiring within 7 Days"/>
                            <ComboBoxItem Content="Expired (Past 30 Days)"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Right: Search -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Search Member" Foreground="Gray" FontSize="12" Margin="0,0,0,8"/>
                        <Border Background="#1a1a1c" BorderBrush="#333" BorderThickness="1"
                                CornerRadius="8" Padding="10,0" Height="36">
                            <DockPanel VerticalAlignment="Center">
                                <TextBlock Text="🔍" FontSize="14" Foreground="Gray"
                                           VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                                <TextBox x:Name="txtExpirationSearch" Background="Transparent"
                                         BorderThickness="0" Foreground="White" CaretBrush="White"
                                         FontSize="13" VerticalAlignment="Center"
                                         Tag="Search by member name..."
                                         TextChanged="TxtExpirationSearch_TextChanged">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                                          Background="Transparent"
                                                                          VerticalAlignment="Center"/>
                                                            <TextBlock Foreground="Gray" FontSize="13"
                                                                       VerticalAlignment="Center"
                                                                       IsHitTestVisible="False"
                                                                       Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=TextBox}}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Summary Cards -->
            <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,15">

                <!-- Critical Count -->
                <Border CornerRadius="15" Padding="20" Margin="0,0,8,0" Height="180" Background="#3a1020">
                    <DockPanel VerticalAlignment="Center">
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                            <Border Width="36" Height="36" Background="#5a1a30" CornerRadius="10"
                                    HorizontalAlignment="Left" Margin="0,0,0,12">
                                <TextBlock Text="⚠" FontSize="18" Foreground="#ff4060"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Critical Count (48 Hours)" Foreground="#cc7788" FontSize="13"/>
                            <TextBlock x:Name="lblCriticalCount" Text="0" Foreground="White"
                                       FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock Text="Immediate action needed" Foreground="#885566"
                                       FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Pending Renewals -->
                <Border CornerRadius="15" Padding="20" Margin="8,0,0,0" Height="180" Background="#3a2010">
                    <DockPanel VerticalAlignment="Center">
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                            <Border Width="36" Height="36" Background="#5a3010" CornerRadius="10"
                                    HorizontalAlignment="Left" Margin="0,0,0,12">
                                <TextBlock Text="⏱" FontSize="18" Foreground="#ffaa40"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Pending Renewals" Foreground="#cc9966" FontSize="13"/>
                            <TextBlock x:Name="lblPendingRenewals" Text="0" Foreground="White"
                                       FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock Text="Already expired members" Foreground="#886644"
                                       FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <!-- Expirations DataGrid -->
            <Border Grid.Row="2" Background="#141416" CornerRadius="15" Padding="10">
                <DataGrid x:Name="dgExpirations" Background="Transparent" BorderThickness="0"
                          Foreground="White" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#1e1e20" RowHeight="56" FontSize="14"
                          HeadersVisibility="Column">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#2a2a2c"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#202022"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="15,0" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <!-- Expired: subtle red tint -->
                                <DataTrigger Binding="{Binding UrgencyLevel}" Value="Expired">
                                    <Setter Property="Background" Value="#1f0a0a"/>
                                </DataTrigger>
                                <!-- Critical <=2 days: subtle yellow/amber tint -->
                                <DataTrigger Binding="{Binding UrgencyLevel}" Value="Critical">
                                    <Setter Property="Background" Value="#1a1500"/>
                                </DataTrigger>
                                <!-- Warning 3-7 days: subtle blue tint -->
                                <DataTrigger Binding="{Binding UrgencyLevel}" Value="Warning">
                                    <Setter Property="Background" Value="#050d1a"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#252528"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>

                        <!-- Member Name with urgency dot -->
                        <DataGridTemplateColumn Header="Member Name" Width="1.8*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse x:Name="UrgencyDot" Width="8" Height="8"
                         Margin="0,0,8,0" VerticalAlignment="Center"
                         Fill="Transparent"/>
                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding DaysRemaining}" Value="0">
                                            <Setter TargetName="UrgencyDot" Property="Fill" Value="#ff4060"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Phone Number -->
                        <DataGridTextColumn Header="Phone Number" Binding="{Binding Phone}" Width="1.4*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#aaaaaa"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Plan Type badge -->
                        <DataGridTemplateColumn Header="Plan Type" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="PlanBadge" CornerRadius="6" Padding="10,4"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Background="#2a2a2c">
                                        <TextBlock x:Name="PlanText" Text="{Binding PlanType}"
                                                   FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding PlanType}" Value="Daily">
                                            <Setter TargetName="PlanBadge" Property="Background" Value="#3a2200"/>
                                            <Setter TargetName="PlanText"  Property="Foreground" Value="#ff9940"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PlanType}" Value="Weekly">
                                            <Setter TargetName="PlanBadge" Property="Background" Value="#0a2a2a"/>
                                            <Setter TargetName="PlanText"  Property="Foreground" Value="#30c0b0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PlanType}" Value="Half-Month">
                                            <Setter TargetName="PlanBadge" Property="Background" Value="#251a3a"/>
                                            <Setter TargetName="PlanText"  Property="Foreground" Value="#a070f0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PlanType}" Value="Monthly">
                                            <Setter TargetName="PlanBadge" Property="Background" Value="#0a1a3a"/>
                                            <Setter TargetName="PlanText"  Property="Foreground" Value="#4090f0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PlanType}" Value="Yearly">
                                            <Setter TargetName="PlanBadge" Property="Background" Value="#0a2a1a"/>
                                            <Setter TargetName="PlanText"  Property="Foreground" Value="#30c070"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Expiry Date -->
                        <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate}" Width="1.2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#aaaaaa"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Days Remaining with progress bar -->
                        <DataGridTemplateColumn Header="Days Remaining" Width="1.6*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="0,4,0,4">
                                        <TextBlock x:Name="DaysLabel"
                           Text="{Binding DaysRemainingLabel}"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="#aaaaaa" Margin="0,0,0,4"/>
                                        <Border x:Name="ProgressTrack" Height="5" CornerRadius="3"
                        Background="#2a2a2c" Visibility="Visible">
                                            <Border x:Name="ProgressFill" HorizontalAlignment="Left"
                            CornerRadius="3" Background="#4090f0"
                            Width="{Binding ProgressWidth}"/>
                                        </Border>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding UrgencyLevel}" Value="Expired">
                                            <Setter TargetName="DaysLabel"     Property="Foreground" Value="#ff4060"/>
                                            <Setter TargetName="ProgressTrack" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding UrgencyLevel}" Value="Critical">
                                            <Setter TargetName="DaysLabel"    Property="Foreground" Value="#ffcc00"/>
                                            <Setter TargetName="ProgressFill" Property="Background" Value="#ffcc00"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding UrgencyLevel}" Value="Warning">
                                            <Setter TargetName="DaysLabel" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Status badge -->
                        <DataGridTemplateColumn Header="Status" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse x:Name="StatusDot" Width="8" Height="8"
                         VerticalAlignment="Center" Margin="0,0,6,0"
                         Fill="#4090f0"/>
                                        <TextBlock x:Name="StatusLabel" Text="{Binding UrgencyLevel}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#4090f0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding UrgencyLevel}" Value="Expired">
                                            <Setter TargetName="StatusDot"   Property="Fill"       Value="#ff4060"/>
                                            <Setter TargetName="StatusLabel" Property="Foreground" Value="#ff4060"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding UrgencyLevel}" Value="Critical">
                                            <Setter TargetName="StatusDot"   Property="Fill"       Value="#ffcc00"/>
                                            <Setter TargetName="StatusLabel" Property="Foreground" Value="#ffcc00"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding UrgencyLevel}" Value="Warning">
                                            <Setter TargetName="StatusDot"   Property="Fill"       Value="#4090f0"/>
                                            <Setter TargetName="StatusLabel" Property="Foreground" Value="#4090f0"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

    </Grid>
</UserControl>