<UserControl x:Class="GymManagementSystem.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <UserControl.Resources>
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock x:Name="Icon" Text="{TemplateBinding Tag}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border x:Name="HighlightBar" Height="3" Background="#ff6b00" VerticalAlignment="Bottom" Visibility="Collapsed" CornerRadius="1.5"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="HighlightBar" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Height" Value="180"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,20,0,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Reports" Foreground="White" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="View and analyze gym performance metrics" Foreground="Gray" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Tab Navigation -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton Content="Financial" Tag="💰" IsChecked="True" Style="{StaticResource TabButtonStyle}" Click="TabFinancial_Click"/>
            <RadioButton Content="Attendance" Tag="📊" Style="{StaticResource TabButtonStyle}" Click="TabAttendance_Click"/>
            <RadioButton Content="Expirations" Tag="⏰" Style="{StaticResource TabButtonStyle}" Click="TabExpirations_Click"/>
        </StackPanel>

        <Separator Grid.Row="1" VerticalAlignment="Bottom" Background="#333" Margin="0,0,0,0"/>

        <!-- Central Content Area -->
        <ContentControl x:Name="ReportsContent" Grid.Row="2" Grid.RowSpan="2" Margin="0,20,0,0">
            <!-- Financial Report View (Default ) -->
            <Grid x:Name="FinancialReportGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filters -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Start Date" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                        <DatePicker x:Name="dpStart" Width="180" Style="{StaticResource ModernDatePicker}"
                            SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="End Date" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                        <DatePicker x:Name="dpEnd" Width="180" Style="{StaticResource ModernDatePicker}"
                            SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Filter by Plan" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                        <ComboBox x:Name="cbPlanFilter" Width="180" Style="{StaticResource ModernComboBox}" SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="All Plans" IsSelected="True"/>
                            <ComboBoxItem Content="Daily"/>
                            <ComboBoxItem Content="Weekly"/>
                            <ComboBoxItem Content="Half-Month"/>
                            <ComboBoxItem Content="Monthly"/>
                            <ComboBoxItem Content="Yearly"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <!-- Summary Cards -->
                <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,30">
                    <Border Style="{StaticResource SummaryCardStyle}" Background="#1a3a2a">
                        <StackPanel VerticalAlignment="Center">
                            <Border Width="40" Height="40" Background="#2a4a3a" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                                <TextBlock Text="💵" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Total Revenue" Foreground="Gray" FontSize="14"/>
                            <TextBlock x:Name="lblTotalRevenue" Text="₱0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SummaryCardStyle}" Background="#1a2a4a">
                        <StackPanel VerticalAlignment="Center">
                            <Border Width="40" Height="40" Background="#2a3a5a" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                                <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Walk-ins (₱90)" Foreground="Gray" FontSize="14"/>
                            <TextBlock x:Name="lblWalkIns" Text="₱0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock x:Name="lblWalkInsCount" Text="0 transactions" Foreground="Gray" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SummaryCardStyle}" Background="#3a2a1a" Margin="0,0,0,0">
                        <StackPanel VerticalAlignment="Center">
                            <Border Width="40" Height="40" Background="#4a3a2a" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                                <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Subscriptions" Foreground="LightGray" FontSize="14"/>
                            <TextBlock x:Name="lblSubscriptions" Text="₱0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock x:Name="lblSubscriptionsCount" Text="0 transactions" Foreground="LightGray" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Transaction History -->
                <Border Grid.Row="2" Background="#141416" CornerRadius="15" Padding="10">
                    <DataGrid x:Name="dgTransactions" Background="Transparent" BorderThickness="0" Foreground="White" 
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              RowBackground="Transparent" AlternatingRowBackground="#1a1a1c" GridLinesVisibility="None">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="Gray"/>
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#333"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding DateOfTransaction}" Width="*"/>
                            <DataGridTextColumn Header="Member Name" Binding="{Binding MemberName}" Width="1.5*"/>
                            <DataGridTextColumn Header="Plan" Binding="{Binding MembershipType}" Width="*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountPaid, StringFormat=₱\{0:N0\}}" Width="*"/>
                            <DataGridTextColumn Header="Payment Method" Binding="{Binding PaymentMode}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </ContentControl>
    </Grid>
</UserControl>
