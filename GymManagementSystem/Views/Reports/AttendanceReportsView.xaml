<UserControl x:Class="GymManagementSystem.Views.Reports.AttendanceReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.Views.Reports"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="AttendanceReportGrid" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Filters Bar -->
            <Border Grid.Row="0" Background="{DynamicResource ThemePanelBg}" CornerRadius="12" Padding="12" Margin="0,0,0,15">
                <DockPanel LastChildFill="False">

                    <!-- Date Navigator (Left) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left" Margin="0,0,12,0">
                        <Button x:Name="btnPrevDay" Content="‹" Style="{StaticResource NavButtonStyle}" Click="BtnPrevDay_Click" Margin="0,0,8,0"/>
                        <DatePicker x:Name="dpAttendanceDate" Width="160" Style="{StaticResource ModernDatePicker}" SelectedDateChanged="DpAttendanceDate_SelectedDateChanged"/>
                        <Button x:Name="btnNextDay" Content="›" Style="{StaticResource NavButtonStyle}" Click="BtnNextDay_Click" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Segmented Control: Members | Instructors -->
                    <Border DockPanel.Dock="Left"
                            Background="{DynamicResource ThemeInputBg}" 
                            BorderBrush="{DynamicResource ThemeInputBorder}" BorderThickness="1"
                            CornerRadius="10" 
                            Height="36"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal" Margin="3">
                            <RadioButton x:Name="tabMembers"
                                         Content="👤  Members"
                                         IsChecked="True"
                                         Style="{StaticResource SegmentedButtonStyle}"
                                         Click="TabMembers_Click"/>
                            <RadioButton x:Name="tabInstructors"
                                         Content="🏋️  Instructors"
                                         Style="{StaticResource SegmentedButtonStyle}"
                                         Click="TabInstructors_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Right-side controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right">

                        <!-- Search Bar -->
                        <Border Background="{DynamicResource ThemeInputBg}" BorderBrush="{DynamicResource ThemeInputBorder}" BorderThickness="1" CornerRadius="8" Padding="8,0" Width="220" Height="36" Margin="0,0,8,0">
                            <DockPanel VerticalAlignment="Center">
                                <TextBlock Text="🔍" FontSize="14" Foreground="{DynamicResource ThemeFgSecondary}" VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                                <TextBox x:Name="txtAttendanceSearch" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeFgPrimary}" CaretBrush="{DynamicResource ThemeFgPrimary}" FontSize="13" VerticalAlignment="Center" Tag="Search name..." TextChanged="TxtAttendanceSearch_TextChanged">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent" VerticalAlignment="Center"/>
                                                            <TextBlock Foreground="{DynamicResource ThemeFgSecondary}" FontSize="13" VerticalAlignment="Center" IsHitTestVisible="False" Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=TextBox}}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </DockPanel>
                        </Border>

                        <!-- Member Plan Filter -->
                        <ComboBox x:Name="cbPlanFilter" 
                                  Width="150" 
                                  Height="36" 
                                  Margin="0,0,8,0"
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="FilterPlan_SelectionChanged">
                            <ComboBoxItem Content="All Plans" IsSelected="True"/>
                        </ComboBox>

                        <!-- Instructor Specialization Filter (Hidden by default) -->
                        <ComboBox x:Name="cbSpecializationFilter" 
                                  Width="150" 
                                  Height="36" 
                                  Margin="0,0,8,0"
                                  Visibility="Collapsed"
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="FilterSpecialization_SelectionChanged">
                            <ComboBoxItem Content="All Specs" IsSelected="True"/>
                        </ComboBox>

                        <Button x:Name="btnRefreshAttendance" Style="{StaticResource IconButtonStyle}" Click="BtnRefreshAttendance_Click" ToolTip="Refresh">
                            <TextBlock Text="↺" FontSize="18" Foreground="{DynamicResource ThemeFgPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource ModernGradientButton}" Padding="18,10" Margin="8,0,0,0" Click="ExportCsv_Click">
                            <TextBlock Text="Export CSV" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- Summary Cards -->
            <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,15">
                <Border Style="{StaticResource SummaryCardStyle}" Background="{DynamicResource ThemeOccupancyBg}" BorderBrush="{DynamicResource ThemeOccupancyBorder}" Margin="0,0,8,0">
                    <DockPanel VerticalAlignment="Center">
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                            <TextBlock x:Name="lblTotalVisitorsTitle" Text="Total Visitors Today" Foreground="{DynamicResource ThemeOccupancyLabelFg}" FontSize="13"/>
                            <TextBlock x:Name="lblTotalVisitors" Text="0" Foreground="{DynamicResource ThemeOccupancyFg}" FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border x:Name="brdVisitorsIcon" Width="48" Height="48" Background="{DynamicResource ThemeOccupancyBorder}" CornerRadius="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="👥" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DockPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Background="{DynamicResource ThemeNewMembersBg}" BorderBrush="{DynamicResource ThemeNewMembersBorder}" Margin="8,0,0,0">
                    <DockPanel VerticalAlignment="Center">
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                            <TextBlock Text="Peak Hour" Foreground="{DynamicResource ThemeNewMembersLabelFg}" FontSize="13"/>
                            <TextBlock x:Name="lblPeakHour" Text="--" Foreground="{DynamicResource ThemeNewMembersFg}" FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Width="48" Height="48" Background="{DynamicResource ThemeNewMembersBorder}" CornerRadius="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="📈" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <!-- Report Grids -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <!-- MEMBER DATA GRID -->
                <Border x:Name="brdMemberGrid" Background="{DynamicResource ThemePanelBg}" CornerRadius="15" Padding="10" Visibility="Visible">
                    <DataGrid x:Name="dgAttendanceReport" 
                              Style="{StaticResource ModernDataGrid}"
                              IsReadOnly="True"
                              RowHeaderWidth="0"
                              RowHeight="52" 
                              FontSize="14"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time of Entry" Binding="{Binding CheckInTime}" Width="1.2*"/>
                            <DataGridTextColumn Header="Time Out" Binding="{Binding CheckOutTime}" Width="1.2*"/>
                            <DataGridTextColumn Header="Member Name" Binding="{Binding Name}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ThemeFgPrimary}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Membership Plan" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding MembershipType}" 
                                                        Style="{StaticResource MembershipPlanBadge}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- INSTRUCTOR DATA GRID -->
                <Border x:Name="brdInstructorGrid" Background="{DynamicResource ThemePanelBg}" CornerRadius="15" Padding="10" Visibility="Collapsed">
                    <DataGrid x:Name="dgInstructorAttendanceReport" 
                              Style="{StaticResource ModernDataGrid}"
                              IsReadOnly="True"
                              RowHeaderWidth="0"
                              RowHeight="52" 
                              FontSize="14"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time of Entry" Binding="{Binding CheckInTime}" Width="1.2*"/>
                            <DataGridTextColumn Header="Time Out" Binding="{Binding CheckOutTime}" Width="1.2*"/>
                            <DataGridTextColumn Header="Instructor Name" Binding="{Binding Name}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ThemeFgPrimary}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Specialization" Binding="{Binding Specialization}" Width="1.8*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="LightBlue"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
