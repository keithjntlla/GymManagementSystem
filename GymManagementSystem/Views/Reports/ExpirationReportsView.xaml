<UserControl x:Class="GymManagementSystem.Views.Reports.ExpirationReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.Views.Reports"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">

    <Grid x:Name="ExpirationsReportGrid" Margin="0,20,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#141416" CornerRadius="12" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Expiration Window" Foreground="Gray" FontSize="12" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cbExpirationWindow" Width="220" Height="40"
                          Style="{StaticResource ModernComboBox}"
                          SelectionChanged="CbExpirationWindow_SelectionChanged">
                        <ComboBoxItem Content="Expiring Today"           IsSelected="True"/>
                        <ComboBoxItem Content="Expiring within 3 Days"/>
                        <ComboBoxItem Content="Expiring within 7 Days"/>
                        <ComboBoxItem Content="Expired (Past 30 Days)"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Search Member" Foreground="Gray" FontSize="12" Margin="0,0,0,8"/>
                    <Border Background="#1a1a1c" BorderBrush="#333" BorderThickness="1"
                        CornerRadius="8" Padding="10,0" Height="40">
                        <DockPanel VerticalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="14" Foreground="Gray"
                                   VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                            <TextBox x:Name="txtExpirationSearch" Background="Transparent"
                                 BorderThickness="0" Foreground="White" CaretBrush="White"
                                 FontSize="13" VerticalAlignment="Center"
                                 Tag="Search by member name..."
                                 TextChanged="TxtExpirationSearch_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Grid>
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                  Background="Transparent"
                                                                  VerticalAlignment="Center"/>
                                                        <TextBlock Foreground="Gray" FontSize="13"
                                                               VerticalAlignment="Center"
                                                               IsHitTestVisible="False"
                                                               Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=TextBox}}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,15">
            <Border CornerRadius="15" Padding="20" Margin="0,0,8,0" Height="180" Background="#3a1020">
                <DockPanel VerticalAlignment="Center">
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Border Width="36" Height="36" Background="#5a1a30" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <TextBlock Text="⚠" FontSize="18" Foreground="#ff4060" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Critical Count (48 Hours)" Foreground="#cc7788" FontSize="13"/>
                        <TextBlock x:Name="lblCriticalCount" Text="0" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                        <TextBlock Text="Immediate action needed" Foreground="#885566" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border CornerRadius="15" Padding="20" Margin="8,0,0,0" Height="180" Background="#3a2010">
                <DockPanel VerticalAlignment="Center">
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Border Width="36" Height="36" Background="#5a3010" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <TextBlock Text="⏱" FontSize="18" Foreground="#ffaa40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Pending Renewals" Foreground="#cc9966" FontSize="13"/>
                        <TextBlock x:Name="lblPendingRenewals" Text="0" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                        <TextBlock Text="Already expired members" Foreground="#886644" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="#141416" CornerRadius="15" Padding="10" Margin="0,0,0,10">
            <DataGrid x:Name="dgExpirations" 
                      Style="{StaticResource ModernDataGrid}"
                      IsReadOnly="True"
                      RowHeaderWidth="0"
                      RowHeight="56" 
                      FontSize="14"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding UrgencyLevel}" Value="Expired">
                                <Setter Property="Background" Value="#1f0a0a"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding UrgencyLevel}" Value="Critical">
                                <Setter Property="Background" Value="#1a1500"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding UrgencyLevel}" Value="Warning">
                                <Setter Property="Background" Value="#050d1a"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252528"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Member Name" Width="1.8*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="UrgencyDot" Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center" Fill="Transparent"/>
                                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding DaysRemaining}" Value="0">
                                        <Setter TargetName="UrgencyDot" Property="Fill" Value="#ff4060"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Phone Number" Binding="{Binding Phone}" Width="1.4*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#aaaaaa"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Plan Type" Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="PlanBadge" CornerRadius="6" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#2a2a2c">
                                    <TextBlock x:Name="PlanText" Text="{Binding PlanType}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding PlanType}" Value="Daily">
                                        <Setter TargetName="PlanBadge" Property="Background" Value="#3a2200"/>
                                        <Setter TargetName="PlanText"  Property="Foreground" Value="#ff9940"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PlanType}" Value="Weekly">
                                        <Setter TargetName="PlanBadge" Property="Background" Value="#0a2a2a"/>
                                        <Setter TargetName="PlanText"  Property="Foreground" Value="#30c0b0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PlanType}" Value="Half-Month">
                                        <Setter TargetName="PlanBadge" Property="Background" Value="#251a3a"/>
                                        <Setter TargetName="PlanText"  Property="Foreground" Value="#a070f0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PlanType}" Value="Monthly">
                                        <Setter TargetName="PlanBadge" Property="Background" Value="#0a1a3a"/>
                                        <Setter TargetName="PlanText"  Property="Foreground" Value="#4090f0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PlanType}" Value="Yearly">
                                        <Setter TargetName="PlanBadge" Property="Background" Value="#0a2a1a"/>
                                        <Setter TargetName="PlanText"  Property="Foreground" Value="#30c070"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate}" Width="1.2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#aaaaaa"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Days Remaining" Width="1.6*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="0,4,0,4">
                                    <TextBlock x:Name="DaysLabel" Text="{Binding DaysRemainingLabel}" FontWeight="SemiBold" FontSize="13" Foreground="#aaaaaa" Margin="0,0,0,4"/>
                                    <Border x:Name="ProgressTrack" Height="5" CornerRadius="3" Background="#2a2a2c" Visibility="Visible">
                                        <Border x:Name="ProgressFill" HorizontalAlignment="Left" CornerRadius="3" Background="#4090f0" Width="{Binding ProgressWidth}"/>
                                    </Border>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding UrgencyLevel}" Value="Expired">
                                        <Setter TargetName="DaysLabel"     Property="Foreground" Value="#ff4060"/>
                                        <Setter TargetName="ProgressTrack" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding UrgencyLevel}" Value="Critical">
                                        <Setter TargetName="DaysLabel"    Property="Foreground" Value="#ffcc00"/>
                                        <Setter TargetName="ProgressFill" Property="Background" Value="#ffcc00"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding UrgencyLevel}" Value="Warning">
                                        <Setter TargetName="DaysLabel" Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Status" Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="StatusDot" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0" Fill="#4090f0"/>
                                    <TextBlock x:Name="StatusLabel" Text="{Binding UrgencyLevel}" FontSize="12" FontWeight="SemiBold" Foreground="#4090f0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding UrgencyLevel}" Value="Expired">
                                        <Setter TargetName="StatusDot"   Property="Fill"       Value="#ff4060"/>
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="#ff4060"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding UrgencyLevel}" Value="Critical">
                                        <Setter TargetName="StatusDot"   Property="Fill"       Value="#ffcc00"/>
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="#ffcc00"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding UrgencyLevel}" Value="Warning">
                                        <Setter TargetName="StatusDot"   Property="Fill"       Value="#4090f0"/>
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="#4090f0"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>