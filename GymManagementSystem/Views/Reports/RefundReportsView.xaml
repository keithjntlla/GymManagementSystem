<UserControl x:Class="GymManagementSystem.Views.Reports.RefundReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GymManagementSystem.Views.Reports"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="RefundReportGrid" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Filter / Export bar -->
            <Border Grid.Row="0" Background="#141416" CornerRadius="12" Padding="15" Margin="0,0,0,25">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Start Date" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                        <DatePicker x:Name="dpStart" Width="160" Height="40"
                                    Style="{StaticResource ModernDatePicker}"
                                    SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="End Date" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                        <DatePicker x:Name="dpEnd" Width="160" Height="40"
                                    Style="{StaticResource ModernDatePicker}"
                                    SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,16,0">
                        <TextBlock Text="Filter by Plan" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                        <ComboBox x:Name="cbPlanFilter"
                                  Width="160"
                                  Height="40"
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="All Plans" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,16,0">
                        <TextBlock Text="Filter by Reason" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                        <ComboBox x:Name="cbReasonFilter"
                                  Width="175"
                                  Height="40"
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="All Reasons" IsSelected="True"/>
                            <ComboBoxItem Content="Member Request"/>
                            <ComboBoxItem Content="Double Payment"/>
                            <ComboBoxItem Content="Plan Change"/>
                            <ComboBoxItem Content="Health Reason"/>
                            <ComboBoxItem Content="Service Complaint"/>
                            <ComboBoxItem Content="Billing Error"/>
                            <ComboBoxItem Content="Other"/>
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="5"
                            Style="{StaticResource ModernGradientButton}"
                            Padding="18,10"
                            VerticalAlignment="Bottom"
                            Click="ExportCsv_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Export CSV" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Summary cards -->
            <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,30">
                <Border Style="{StaticResource SummaryCardStyle}" Background="#3B1214" BorderBrush="#5c2025" Margin="0,0,10,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#5A1B1E" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="↩" FontSize="20" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Total Refunds" Foreground="#E5E7EB" FontSize="14"/>
                        <TextBlock Text="{Binding TotalRefundsCount, FallbackValue='0'}" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}" Background="#29123A" BorderBrush="#412b5c" Margin="10,0,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#3C1C55" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="₱" FontSize="20" Foreground="#E879F9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Total Amount" Foreground="#E5E7EB" FontSize="14"/>
                        <TextBlock Text="{Binding TotalRefundsAmount, StringFormat=₱\{0:N2\}, FallbackValue='₱0.00'}" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Data table -->
            <Border Grid.Row="2" Background="#141416" CornerRadius="15" Padding="10" Margin="0,0,0,10">
                <DataGrid x:Name="dgRefundTransactions"
                          ItemsSource="{Binding RefundTransactions}"
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Refund ID"   Binding="{Binding RefundId}"      Width="0.9*"/>
                        <DataGridTextColumn Header="Date"        Binding="{Binding FormattedDate}" Width="0.9*"/>
                        <DataGridTextColumn Header="Member Name" Binding="{Binding MemberName}"    Width="1.4*"/>

                        <DataGridTemplateColumn Header="Plan" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding PlanName}"
                                                    Style="{StaticResource MembershipPlanBadge}"
                                                    VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Reason + Notes column -->
                        <DataGridTemplateColumn Header="Reason" Width="1.4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="4,2">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="{Binding RefundReason}"/>
                                                    <Setter Property="Foreground" Value="#fbbf24"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RefundReason}" Value="">
                                                            <Setter Property="Text"       Value="—"/>
                                                            <Setter Property="Foreground" Value="#52525B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding RefundNotes}"
                                                   Foreground="#888" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RefundNotes}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Refund Amount" Binding="{Binding RefundAmount, StringFormat=₱\{0:N2\}}" Width="1.1*" Foreground="#EF4444" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Processed By"  Binding="{Binding ProcessedBy}"                          Width="1.1*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <TextBlock Grid.Row="3"
                       Text="{Binding RefundTransactions.Count, StringFormat='Showing {0} refunds', FallbackValue='Showing 0 refunds'}"
                       HorizontalAlignment="Center"
                       Foreground="#52525B"
                       FontSize="14"
                       Margin="0,5,0,10"/>
        </Grid>
    </ScrollViewer>
</UserControl>
