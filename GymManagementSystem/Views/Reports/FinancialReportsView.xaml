<UserControl x:Class="GymManagementSystem.Views.Reports.FinancialReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.Views.Reports"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">

    <UserControl.Resources>
        <Style x:Key="PopupCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent" Cursor="Hand">
                            <BulletDecorator.Bullet>
                                <Border x:Name="Border" 
                                        Width="16" Height="16" 
                                        CornerRadius="3" 
                                        Background="#141416" 
                                        BorderBrush="#333" 
                                        BorderThickness="1"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <Path x:Name="CheckMark" 
                                          Width="10" Height="8" 
                                          SnapsToDevicePixels="True" 
                                          Fill="#ff6b00" 
                                          Stretch="Fill" 
                                          Data="M 0 4 L 3 7 L 9 1 C 9 1 9 1 9 1 Z" 
                                          Visibility="Collapsed"/>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter HorizontalAlignment="Left" 
                                               VerticalAlignment="Center" 
                                               Margin="8,0,0,0"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#ff6b00"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#ff6b00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="FinancialReportGrid" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="247*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#141416" CornerRadius="12" Padding="15" Margin="0,0,0,25" Grid.ColumnSpan="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Period" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                        <ComboBox x:Name="cbPeriod" Width="140" Height="40" 
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="Period_SelectionChanged">
                            <ComboBoxItem Content="This Month"/>
                            <ComboBoxItem Content="This Week"/>
                            <ComboBoxItem Content="This Year"/>
                            <ComboBoxItem Content="Custom" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                        <TextBlock Text="Start Date" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                        <DatePicker x:Name="dpStart" Width="150" Height="40" 
                                    Style="{StaticResource ModernDatePicker}"
                                    SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,20,0">
                        <TextBlock Text="End Date" Foreground="Gray" Margin="0,0,0,8" FontSize="12"/>
                        <DatePicker x:Name="dpEnd" Width="150" Height="40" 
                                    Style="{StaticResource ModernDatePicker}"
                                    SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,15,0" Height="40">
                        <Button x:Name="btnFilter" 
                                Click="FilterButton_Click" 
                                Content="Filter ▾" 
                                Background="#1a1a1c"
                                Foreground="White"
                                BorderBrush="#333"
                                BorderThickness="1"
                                Width="90" Height="40" 
                                Margin="0,0,15,0"
                                VerticalAlignment="Center"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a2a2c"/>
                                            <Setter Property="BorderBrush" Value="#ff6b00"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Popup x:Name="popFilter" PlacementTarget="{Binding ElementName=btnFilter}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="#1a1a1c" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="15" Width="200" Margin="0,5,0,0">
                                <StackPanel>
                                    <!-- Mode Category -->
                                    <TextBlock Text="PAYMENT MODE" Foreground="Gray" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="chkModeCash" Content="Cash" Style="{StaticResource PopupCheckBox}" Checked="FilterCheckbox_Changed" Unchecked="FilterCheckbox_Changed"/>
                                    <CheckBox x:Name="chkModeGCash" Content="GCash" Style="{StaticResource PopupCheckBox}" Checked="FilterCheckbox_Changed" Unchecked="FilterCheckbox_Changed" Margin="0,0,0,12"/>

                                    <!-- Member Type Category -->
                                    <TextBlock Text="MEMBER TYPE" Foreground="Gray" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="chkTypeRegular" Content="Regular" Style="{StaticResource PopupCheckBox}" Checked="FilterCheckbox_Changed" Unchecked="FilterCheckbox_Changed"/>
                                    <CheckBox x:Name="chkTypeStudent" Content="Student" Style="{StaticResource PopupCheckBox}" Checked="FilterCheckbox_Changed" Unchecked="FilterCheckbox_Changed"/>
                                    <StackPanel x:Name="spDynamicTypes" Margin="0,0,0,12"/>
                                    
                                    <!-- Divider line -->
                                    <Border BorderBrush="#333" BorderThickness="0,0,0,1" Margin="0,4,0,12"/>

                                    <!-- Plan Category -->
                                    <TextBlock Text="PLAN TYPE" Foreground="Gray" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <StackPanel x:Name="spDynamicPlans"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                        
                        <WrapPanel x:Name="wpChips" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="4"
                            Style="{StaticResource ModernGradientButton}"
                            Padding="18,10"
                            VerticalAlignment="Bottom"
                            Click="ExportCsv_Click">
                        <TextBlock Text="Export CSV" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    </Button>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,30" Grid.ColumnSpan="2">
                <Border Style="{StaticResource SummaryCardStyle}" Background="#1a3a2a" BorderBrush="#26593f" Margin="0,0,8,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#2a4a3a" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="💵" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Total Revenue" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblTotalRevenue" Text="₱0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Background="#1a2a4a" BorderBrush="#2b4273" Margin="0,0,8,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#2a3a5a" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Walk-ins (₱90)" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblWalkIns" Text="₱0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblWalkInsCount" Text="0 transactions" Foreground="Gray" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Background="#3a2a1a" BorderBrush="#5c4530" Margin="0,0,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#4a3a2a" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Subscriptions" Foreground="LightGray" FontSize="14"/>
                        <TextBlock x:Name="lblSubscriptions" Text="₱0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblSubscriptionsCount" Text="0 transactions" Foreground="LightGray" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Background="#141416" CornerRadius="15" Padding="10" Margin="0,0,0,10" Grid.ColumnSpan="2">
                <DataGrid x:Name="dgTransactions" 
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date"           Binding="{Binding DateOfTransaction}" Width="*"/>
                        <DataGridTextColumn Header="Member Name"    Binding="{Binding MemberName}"        Width="1.5*"/>
                        <DataGridTextColumn Header="Member Type"    Binding="{Binding MemberType}"        Width="*"/>
                        
                        <DataGridTemplateColumn Header="Plan Type" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding MembershipType}" 
                                Style="{StaticResource MembershipPlanBadge}"
                                VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Amount" 
                                            Binding="{Binding TotalAmount, StringFormat=₱\{0:N0\}}" 
                                            Width="*" 
                                            Foreground="#4caf50" 
                                            FontWeight="SemiBold"/>

                        <DataGridTemplateColumn Header="Mode" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="modeBorder" CornerRadius="6" Padding="6,3" Background="#1a2b1a" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock x:Name="modeText" Text="{Binding PaymentMode}" Foreground="#81c784" FontSize="11"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding PaymentMode}" Value="GCash">
                                            <Setter TargetName="modeBorder" Property="Background" Value="#0d1f3d"/>
                                            <Setter TargetName="modeText" Property="Foreground" Value="#4a90e2"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
