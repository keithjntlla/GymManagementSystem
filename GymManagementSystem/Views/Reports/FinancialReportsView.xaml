<UserControl x:Class="GymManagementSystem.Views.Reports.FinancialReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.Views.Reports"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">

    <UserControl.Resources>
        <Style x:Key="PopupCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeFgPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent" Cursor="Hand">
                            <BulletDecorator.Bullet>
                                <Border x:Name="Border" 
                                        Width="16" Height="16" 
                                        CornerRadius="3" 
                                        Background="{DynamicResource ThemeInputBg}" 
                                        BorderBrush="{DynamicResource ThemeInputBorder}" 
                                        BorderThickness="1"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <Path x:Name="CheckMark" 
                                          Width="10" Height="8" 
                                          SnapsToDevicePixels="True" 
                                          Fill="#ff6b00" 
                                          Stretch="Fill" 
                                          Data="M 0 4 L 3 7 L 9 1 C 9 1 9 1 9 1 Z" 
                                          Visibility="Collapsed"/>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter HorizontalAlignment="Left" 
                                               VerticalAlignment="Center" 
                                               Margin="8,0,0,0"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#ff6b00"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#ff6b00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="FinancialReportGrid" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="247*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource ThemePanelBg}" CornerRadius="12" Padding="15" Margin="0,0,0,25" Grid.ColumnSpan="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Period" Foreground="{DynamicResource ThemeFgSecondary}" Margin="0,0,0,8" FontSize="12"/>
                        <ComboBox x:Name="cbPeriod" Width="140" Height="40" 
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="Period_SelectionChanged">
                            <ComboBoxItem Content="This Month"/>
                            <ComboBoxItem Content="This Week"/>
                            <ComboBoxItem Content="This Year"/>
                            <ComboBoxItem Content="Custom" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                        <TextBlock Text="Start Date" Foreground="{DynamicResource ThemeFgSecondary}" Margin="0,0,0,8" FontSize="12"/>
                        <DatePicker x:Name="dpStart" Width="150" Height="40" 
                                    Style="{StaticResource ModernDatePicker}"
                                    SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,20,0">
                        <TextBlock Text="End Date" Foreground="{DynamicResource ThemeFgSecondary}" Margin="0,0,0,8" FontSize="12"/>
                        <DatePicker x:Name="dpEnd" Width="150" Height="40" 
                                    Style="{StaticResource ModernDatePicker}"
                                    SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,15,0" Height="40">
                        <Button x:Name="btnFilter" 
                                Click="FilterButton_Click" 
                                Content="Filter ▾" 
                                Background="{DynamicResource ThemeNavBtnBg}"
                                Foreground="{DynamicResource ThemeFgPrimary}"
                                BorderBrush="{DynamicResource ThemeNavBtnBorder}"
                                BorderThickness="1"
                                Width="90" Height="40" 
                                Margin="0,0,15,0"
                                VerticalAlignment="Center"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ThemeNavBtnHoverBg}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorder}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Popup x:Name="popFilter" PlacementTarget="{Binding ElementName=btnFilter}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="{DynamicResource ThemeDropdownBg}" BorderBrush="{DynamicResource ThemeDropdownBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Width="200" Margin="0,5,0,0">
                                <StackPanel>
                                    <!-- Mode Category -->
                                    <TextBlock Text="PAYMENT MODE" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="chkModeCash" Content="Cash" Style="{StaticResource PopupCheckBox}" Checked="FilterCheckbox_Changed" Unchecked="FilterCheckbox_Changed"/>
                                    <CheckBox x:Name="chkModeGCash" Content="GCash" Style="{StaticResource PopupCheckBox}" Checked="FilterCheckbox_Changed" Unchecked="FilterCheckbox_Changed" Margin="0,0,0,12"/>

                                    <!-- Member Type Category -->
                                    <TextBlock Text="MEMBER TYPE" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="chkTypeRegular" Content="Regular" Style="{StaticResource PopupCheckBox}" Checked="FilterCheckbox_Changed" Unchecked="FilterCheckbox_Changed"/>
                                    <CheckBox x:Name="chkTypeStudent" Content="Student" Style="{StaticResource PopupCheckBox}" Checked="FilterCheckbox_Changed" Unchecked="FilterCheckbox_Changed"/>
                                    <StackPanel x:Name="spDynamicTypes" Margin="0,0,0,12"/>
                                    
                                    <!-- Divider line -->
                                    <Border BorderBrush="{DynamicResource ThemeSeparator}" BorderThickness="0,0,0,1" Margin="0,4,0,12"/>

                                    <!-- Discount Category -->
                                    <TextBlock Text="DISCOUNT STATUS" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="chkDiscountedOnly" Content="Discounted Only" Style="{StaticResource PopupCheckBox}" Checked="FilterCheckbox_Changed" Unchecked="FilterCheckbox_Changed"/>
                                    <CheckBox x:Name="chkNoDiscount" Content="No Discount" Style="{StaticResource PopupCheckBox}" Checked="FilterCheckbox_Changed" Unchecked="FilterCheckbox_Changed" Margin="0,0,0,12"/>

                                    <!-- Plan Category -->
                                    <TextBlock Text="PLAN TYPE" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <StackPanel x:Name="spDynamicPlans"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                        
                        <WrapPanel x:Name="wpChips" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="4"
                            Style="{StaticResource ModernGradientButton}"
                            Padding="18,10"
                            VerticalAlignment="Bottom"
                            Click="ExportCsv_Click">
                        <TextBlock Text="Export CSV" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    </Button>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,30" Grid.ColumnSpan="2">
                <Border Style="{StaticResource SummaryCardStyle}" Background="{DynamicResource ThemeTodayRevenueBg}" BorderBrush="{DynamicResource ThemeTodayRevenueBorder}" Margin="0,0,8,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="{DynamicResource ThemeTodayRevenueBorder}" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="💵" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Total Revenue" Foreground="{DynamicResource ThemeTodayRevenueLabelFg}" FontSize="14"/>
                        <TextBlock x:Name="lblTotalRevenue" Text="₱0" Foreground="{DynamicResource ThemeTodayRevenueFg}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Background="{DynamicResource ThemeOccupancyBg}" BorderBrush="{DynamicResource ThemeOccupancyBorder}" Margin="0,0,8,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="{DynamicResource ThemeOccupancyBorder}" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Walk-ins (&#x20B1;90)" Foreground="{DynamicResource ThemeOccupancyLabelFg}" FontSize="14"/>
                        <TextBlock x:Name="lblWalkIns" Text="₱0" Foreground="{DynamicResource ThemeOccupancyFg}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblWalkInsCount" Text="0 transactions" Foreground="{DynamicResource ThemeOccupancyLabelFg}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Background="{DynamicResource ThemeNewMembersBg}" BorderBrush="{DynamicResource ThemeNewMembersBorder}" Margin="0,0,8,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="{DynamicResource ThemeNewMembersBorder}" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Subscriptions" Foreground="{DynamicResource ThemeNewMembersLabelFg}" FontSize="14"/>
                        <TextBlock x:Name="lblSubscriptions" Text="₱0" Foreground="{DynamicResource ThemeNewMembersFg}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblSubscriptionsCount" Text="0 transactions" Foreground="{DynamicResource ThemeNewMembersLabelFg}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SummaryCardStyle}" Background="{DynamicResource ThemeMonthlyRevenueBg}" BorderBrush="{DynamicResource ThemeMonthlyRevenueBorder}" Margin="0,0,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="{DynamicResource ThemeMonthlyRevenueBorder}" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="🏷️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Total Discounts" Foreground="{DynamicResource ThemeMonthlyRevenueLabelFg}" FontSize="14"/>
                        <TextBlock x:Name="lblTotalDiscounts" Text="₱0" Foreground="{DynamicResource ThemeMonthlyRevenueFg}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblTotalDiscountsCount" Text="0 transactions" Foreground="{DynamicResource ThemeMonthlyRevenueLabelFg}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Background="{DynamicResource ThemeTableBg}" CornerRadius="15" Padding="10" Margin="0,0,0,10" Grid.ColumnSpan="2" Effect="{DynamicResource ThemeTableShadow}">
                <DataGrid x:Name="dgTransactions" 
                          Style="{StaticResource ModernDataGrid}"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date"           Binding="{Binding DateOfTransaction}" Width="*"/>
                        <DataGridTextColumn Header="Member Name"    Binding="{Binding MemberName}"        Width="1.5*"/>
                        <DataGridTextColumn Header="Member Type"    Binding="{Binding MemberType}"        Width="*"/>
                        
                        <DataGridTemplateColumn Header="Plan Type" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding MembershipType}" 
                                Style="{StaticResource MembershipPlanBadge}"
                                VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Amount" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock x:Name="amountText" Text="{Binding TotalAmount, StringFormat=₱\{0:N2\}}" Foreground="#4caf50" FontWeight="SemiBold" VerticalAlignment="Center">
                                        <TextBlock.ToolTip>
                                            <ToolTip Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="0" HasDropShadow="True">
                                                <ToolTip.Style>
                                                    <Style TargetType="ToolTip">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDiscount}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToolTip.Style>
                                                <Border Background="{DynamicResource ThemeDropdownBg}" BorderBrush="#ff6b00" BorderThickness="1.5" CornerRadius="8" Padding="12">
                                                    <StackPanel Width="220" Margin="2">
                                                        <TextBlock Text="Savings Breakdown" Foreground="#ff6b00" FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>
                                                        
                                                        <Grid Margin="0,3">
                                                            <TextBlock Text="Original Rate" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11"/>
                                                            <TextBlock Text="{Binding SubtotalAmount, StringFormat=₱\{0:N2\}}" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="11" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        
                                                        <Grid Margin="0,3">
                                                            <TextBlock Text="{Binding DiscountDescription}" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11"/>
                                                            <TextBlock Text="{Binding DiscountAmount, StringFormat=-₱\{0:N2\}}" Foreground="#ff4444" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        
                                                        <Border BorderBrush="{DynamicResource ThemeSeparator}" BorderThickness="0,1,0,0" Margin="0,8,0,8"/>
                                                        
                                                        <Grid Margin="0,3">
                                                            <TextBlock Text="Net Paid" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="12" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding TotalAmount, StringFormat=₱\{0:N2\}}" Foreground="#2ecc71" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                            <Setter TargetName="amountText" Property="Foreground" Value="#ff9800"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Mode" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="modeBorder" CornerRadius="6" Padding="6,3" Background="{DynamicResource ThemeBadgeCashBg}" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock x:Name="modeText" Text="{Binding PaymentMode}" Foreground="{DynamicResource ThemeBadgeCashFg}" FontSize="11"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding PaymentMode}" Value="GCash">
                                            <Setter TargetName="modeBorder" Property="Background" Value="{DynamicResource ThemeBadgeGCashBg}"/>
                                            <Setter TargetName="modeText" Property="Foreground" Value="{DynamicResource ThemeBadgeGCashFg}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
