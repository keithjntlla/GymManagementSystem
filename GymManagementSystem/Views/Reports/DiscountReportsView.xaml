<UserControl x:Class="GymManagementSystem.Views.Reports.DiscountReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.Views.Reports"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="0,20,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Card Summary Grid -->
            <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,30">
                <!-- Promos Active Card -->
                <Border Style="{StaticResource SummaryCardStyle}" Background="#142622" BorderBrush="#22423c" Margin="0,0,8,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#22423c" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="🔥" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Active Campaigns" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblActiveCampaignsCount" Text="0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock Text="currently running" Foreground="Gray" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Promo Savings Card -->
                <Border Style="{StaticResource SummaryCardStyle}" Background="#3a2a1a" BorderBrush="#5c4530" Margin="0,0,8,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#4a3a2a" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="🏷️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Promo Campaign Savings" Foreground="LightGray" FontSize="14"/>
                        <TextBlock x:Name="lblPromoSavings" Text="₱0.00" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblPromoSavingsCount" Text="0 redemptions" Foreground="LightGray" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Member Tier Savings Card -->
                <Border Style="{StaticResource SummaryCardStyle}" Background="#2d1441" BorderBrush="#412b5c" Margin="0,0,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="40" Height="40" Background="#412b5c" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <TextBlock Text="👥" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Fixed Tier Savings" Foreground="LightGray" FontSize="14"/>
                        <TextBlock x:Name="lblTierSavings" Text="₱0.00" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblTierSavingsCount" Text="0 transactions" Foreground="LightGray" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Table 1: Promotional Code Campaign Audit Grid -->
            <StackPanel Grid.Row="1" Margin="0,0,0,25">
                <TextBlock Text="PROMOTIONAL CODE CAMPAIGN AUDIT" Foreground="#ff6b00" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                <Border Background="#141416" CornerRadius="15" Padding="10">
                    <DataGrid x:Name="dgPromoAudit" 
                              Style="{StaticResource ModernDataGrid}"
                              IsReadOnly="True"
                              RowHeaderWidth="0"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Promo Code" Binding="{Binding PromoCode}" Width="1.2*"/>
                            <DataGridTextColumn Header="Campaign Name" Binding="{Binding CampaignName}" Width="1.8*"/>
                            <DataGridTextColumn Header="Discount Value" Binding="{Binding DisplayValue}" Width="1.2*"/>
                            <DataGridTextColumn Header="Redemptions" Binding="{Binding RedemptionCount}" Width="*"/>
                            
                            <DataGridTemplateColumn Header="Total Savings Given" Width="1.3*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TotalSavings, StringFormat=₱\{0:N2\}}" Foreground="#ff6b00" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Campaign Status" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="statusBorder" CornerRadius="6" Padding="6,3" Background="#1a2b1a" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock x:Name="statusText" Text="{Binding CampaignStatus}" Foreground="#81c784" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding CampaignStatus}" Value="Expired">
                                                <Setter TargetName="statusBorder" Property="Background" Value="#3B1214"/>
                                                <Setter TargetName="statusText" Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CampaignStatus}" Value="Inactive">
                                                <Setter TargetName="statusBorder" Property="Background" Value="#2A2A2E"/>
                                                <Setter TargetName="statusText" Property="Foreground" Value="#8A8A93"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>

            <!-- Table 2: Fixed Customer Tier Discounts Audit Grid -->
            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <TextBlock Text="FIXED CUSTOMER TIER SAVINGS AUDIT" Foreground="#ff6b00" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                <Border Background="#141416" CornerRadius="15" Padding="10">
                    <DataGrid x:Name="dgTierAudit" 
                              Style="{StaticResource ModernDataGrid}"
                              IsReadOnly="True"
                              RowHeaderWidth="0"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Customer Tier" Binding="{Binding TierName}" Width="1.5*"/>
                            <DataGridTextColumn Header="Discount Percentage" Binding="{Binding DisplayValue}" Width="1.5*"/>
                            <DataGridTextColumn Header="Redeemed Transactions" Binding="{Binding RedemptionCount}" Width="*"/>
                            
                            <DataGridTemplateColumn Header="Total Savings Given" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TotalSavings, StringFormat=₱\{0:N2\}}" Foreground="#ff6b00" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
