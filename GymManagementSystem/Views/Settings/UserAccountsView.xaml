<UserControl x:Class="GymManagementSystem.Views.Settings.UserAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1100">

    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="User Accounts &amp; Staff Management" 
                       Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,25"
                       VerticalAlignment="Center"/>

            <Button Style="{StaticResource ModernGradientButton}"
                    HorizontalAlignment="Right"
                    Click="btnAddUser_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Add New User" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </DockPanel>

        <Border Grid.Row="1" Background="#141416" CornerRadius="15" Padding="10">
            <DataGrid x:Name="dgUsers" 
                      Style="{StaticResource ModernDataGrid}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      RowHeaderWidth="0"
                      RowHeight="70" 
                      CanUserAddRows="False" 
                      SelectionMode="Single" 
                      HorizontalScrollBarVisibility="Disabled">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Username" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Username}" VerticalAlignment="Center" 
                                           Foreground="White" FontSize="15" Margin="10,0,0,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Role" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12,5" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2D1A3D"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="Staff">
                                                    <Setter Property="Background" Value="#1A2B3D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Role}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#B176F0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="Staff">
                                                        <Setter Property="Foreground" Value="#5BA4E5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Status" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12,5" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A3D25"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Inactive">
                                                    <Setter Property="Background" Value="#3D1A1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="13" FontWeight="SemiBold" Foreground="#5BE582" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Inactive">
                                                        <Setter Property="Foreground" Value="#E55B5B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                     <DataGridTemplateColumn Header="Actions" Width="200">
                         <DataGridTemplateColumn.CellTemplate>
                             <DataTemplate>
                                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                     <Button x:Name="btnEditUser" Width="70" Height="34" FontSize="13" Margin="0,0,8,0"
                                             Background="#1A1A1C" Foreground="White" BorderBrush="#333" BorderThickness="1"
                                             VerticalAlignment="Center" Cursor="Hand" Click="btnEditUser_Click">
                                         <Button.Template>
                                             <ControlTemplate TargetType="Button">
                                                 <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                                     <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                 </Border>
                                             </ControlTemplate>
                                         </Button.Template>
                                         Edit
                                     </Button>

                                     <Button Width="90" Height="34" FontSize="13"
                                             Background="#222" Foreground="#AAA" BorderThickness="0"
                                             VerticalAlignment="Center" Cursor="Hand" Click="btnToggleStatus_Click">
                                         <Button.Template>
                                             <ControlTemplate TargetType="Button">
                                                 <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                     <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                 </Border>
                                             </ControlTemplate>
                                         </Button.Template>
                                         <Button.Style>
                                             <Style TargetType="Button">
                                                 <Setter Property="Content" Value="Deactivate"/>
                                                 <Setter Property="Background" Value="#222"/>
                                                 <Setter Property="Foreground" Value="#AAA"/>
                                                 <Style.Triggers>
                                                     <DataTrigger Binding="{Binding Status}" Value="Inactive">
                                                         <Setter Property="Content" Value="Activate"/>
                                                         <Setter Property="Background" Value="#1A3D25"/>
                                                         <Setter Property="Foreground" Value="#5BE582"/>
                                                     </DataTrigger>
                                                 </Style.Triggers>
                                             </Style>
                                         </Button.Style>
                                     </Button>
                                 </StackPanel>
                             </DataTemplate>
                         </DataGridTemplateColumn.CellTemplate>
                     </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>