<UserControl x:Class="GymManagementSystem.Views.Settings.BackupSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <StackPanel Margin="0,10,0,0">

        <TextBlock Text="Database &amp; Backup" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="24" FontWeight="Bold" Margin="0,0,0,25"/>

        <!-- Two cards side by side -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Backup Card -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeOccupancyBg}" BorderBrush="{DynamicResource ThemeOccupancyBorder}" BorderThickness="1" CornerRadius="16" Padding="25">
                <StackPanel>
                    <!-- Icon -->
                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                               Foreground="{DynamicResource ThemeOccupancyIconFg}" Margin="0,0,0,15"/>

                    <TextBlock Text="Backup Database" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="20"
                               FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Create a backup of all gym data including members, payments, and settings."
                               Foreground="{DynamicResource ThemeFgMuted}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,25"/>

                    <Button x:Name="btnBackup" Content="Backup Now"
                            Height="50" FontSize="16" FontWeight="Bold"
                            Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="btnBackup_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#2563eb"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1d4ed8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Restore Card -->
            <Border Grid.Column="2" Background="{DynamicResource ThemeMonthlyRevenueBg}" BorderBrush="{DynamicResource ThemeMonthlyRevenueBorder}" BorderThickness="1" CornerRadius="16" Padding="25">
                <StackPanel>
                    <!-- Icon -->
                    <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                               Foreground="{DynamicResource ThemeMonthlyRevenueIconFg}" Margin="0,0,0,15"/>

                    <TextBlock Text="Restore Database" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="20"
                               FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Restore gym data from a previous backup file."
                               Foreground="{DynamicResource ThemeFgMuted}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,25"/>

                    <Button x:Name="btnRestore" Content="Restore from Backup"
                            Height="50" FontSize="16" FontWeight="Bold"
                            Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="btnRestore_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#7c3aed"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#6d28d9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Warning note at the bottom -->
        <Border Background="{DynamicResource ThemeNoteAlertBg}" CornerRadius="10" Padding="15" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" Foreground="{DynamicResource ThemeNoteAlertIconFg}" FontSize="18"
                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                    <Run Text="Important:" Foreground="{DynamicResource ThemeNoteAlertIconFg}" FontWeight="Bold"/>
                    <Run Text=" Regular backups are recommended. Store backup files in a safe location. Restoring a backup will replace all current data."
                         Foreground="{DynamicResource ThemeNoteAlertFg}"/>
                </TextBlock>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
