<UserControl x:Class="GymManagementSystem.Views.Settings.AppearanceSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="950" d:DesignWidth="850">

    <UserControl.Resources>
        <!-- Custom visual card style for Themes/Button Styles -->
        <Style x:Key="SelectorCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemePanelBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorder}"/>
                    <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Accent color pill style -->
        <Style x:Key="AccentColorCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorder}"/>
                    <Setter Property="Background" Value="{DynamicResource ThemeNavBtnHoverBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="10,0,10,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. APPEARANCE HEADER -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Settings" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="26" FontWeight="Bold"/>
                <TextBlock Text="Customize your dashboard theme, button style, and accent color" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 2. APPEARANCE SETTINGS MAIN CARD -->
            <Border Grid.Row="1" Background="{DynamicResource ThemePanelBg}" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1" CornerRadius="12" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Appearance" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <!-- THEME SECTION -->
                    <TextBlock Text="Theme" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="14" FontWeight="Medium" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Dark Theme Card -->
                        <Border x:Name="btnThemeDark" Grid.Column="0" Style="{StaticResource SelectorCardStyle}" MouseDown="ThemeDark_Click">
                            <Grid Height="120">
                                <StackPanel VerticalAlignment="Stretch">
                                    <!-- Mini dark theme wireframe mock -->
                                    <Border Background="#101012" Height="70" CornerRadius="6" Padding="8" BorderThickness="1" BorderBrush="#222">
                                        <StackPanel>
                                            <Border Background="#1e1e24" Height="14" CornerRadius="3" Margin="0,0,0,6"/>
                                            <Border Background="#2a2a2c" Height="8" CornerRadius="2" Width="140" HorizontalAlignment="Left" Margin="0,0,0,4"/>
                                            <Border Background="#2a2a2c" Height="8" CornerRadius="2" Width="190" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>
                                    <Grid Margin="0,12,0,0">
                                        <TextBlock Text="Dark" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <Ellipse x:Name="chkDarkTheme" Width="16" Height="16" Fill="{DynamicResource AppAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <!-- Simple badge visual -->
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <!-- Checked mark -->
                                        <TextBlock x:Name="txtDarkThemeCheck" Text="✔" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,3,0" Visibility="Collapsed"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Light Theme Card -->
                        <Border x:Name="btnThemeLight" Grid.Column="2" Style="{StaticResource SelectorCardStyle}" MouseDown="ThemeLight_Click">
                            <Grid Height="120">
                                <StackPanel VerticalAlignment="Stretch">
                                    <!-- Mini light theme wireframe mock -->
                                    <Border Background="#f8f8f9" Height="70" CornerRadius="6" Padding="8" BorderThickness="1" BorderBrush="#ddd">
                                        <StackPanel>
                                            <Border Background="#eef0f2" Height="14" CornerRadius="3" Margin="0,0,0,6"/>
                                            <Border Background="#e1e4e8" Height="8" CornerRadius="2" Width="140" HorizontalAlignment="Left" Margin="0,0,0,4"/>
                                            <Border Background="#e1e4e8" Height="8" CornerRadius="2" Width="190" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>
                                    <Grid Margin="0,12,0,0">
                                        <TextBlock Text="Light" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <Ellipse x:Name="chkLightTheme" Width="16" Height="16" Fill="{DynamicResource AppAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock x:Name="txtLightThemeCheck" Text="✔" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,3,0" Visibility="Collapsed"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- BUTTON STYLE SECTION -->
                    <TextBlock Text="Button Style" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="14" FontWeight="Medium" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Gradient Card -->
                        <Border x:Name="btnStyleGradient" Grid.Column="0" Style="{StaticResource SelectorCardStyle}" MouseDown="StyleGradient_Click">
                            <StackPanel Height="90" VerticalAlignment="Center">
                                <Border Height="36" CornerRadius="18" Margin="0,5,0,15" Width="180">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop x:Name="btnStyleGradColorStart" Color="#ff6b00" Offset="0.0"/>
                                            <GradientStop x:Name="btnStyleGradColorEnd" Color="#ff0000" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="Button" Foreground="White" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <Grid>
                                    <TextBlock Text="Gradient" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                    <Ellipse x:Name="chkStyleGradient" Width="16" Height="16" Fill="{DynamicResource AppAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBlock x:Name="txtStyleGradientCheck" Text="✔" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,3,0" Visibility="Collapsed"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Solid Card -->
                        <Border x:Name="btnStyleSolid" Grid.Column="2" Style="{StaticResource SelectorCardStyle}" MouseDown="StyleSolid_Click">
                            <StackPanel Height="90" VerticalAlignment="Center">
                                <Border x:Name="btnStyleSolidSample" Height="36" CornerRadius="18" Margin="0,5,0,15" Width="180" Background="#e05e00">
                                    <TextBlock Text="Button" Foreground="White" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <Grid>
                                    <TextBlock Text="Solid" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                    <Ellipse x:Name="chkStyleSolid" Width="16" Height="16" Fill="{DynamicResource AppAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBlock x:Name="txtStyleSolidCheck" Text="✔" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,3,0" Visibility="Collapsed"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ACCENT COLOR SECTION -->
                    <TextBlock Text="Accent Color" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="14" FontWeight="Medium" Margin="0,0,0,10"/>
                    <UniformGrid Columns="4" Rows="2">
                        <!-- Orange -->
                        <Border x:Name="colorOrange" Style="{StaticResource AccentColorCardStyle}" Margin="0,0,8,10" MouseDown="ColorOrange_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="18" Height="18" Fill="#e05e00" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblOrange" Text="Orange" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Blue -->
                        <Border x:Name="colorBlue" Style="{StaticResource AccentColorCardStyle}" Margin="0,0,8,10" MouseDown="ColorBlue_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="18" Height="18" Fill="#1b72e8" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblBlue" Text="Blue" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Green -->
                        <Border x:Name="colorGreen" Style="{StaticResource AccentColorCardStyle}" Margin="0,0,8,10" MouseDown="ColorGreen_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="18" Height="18" Fill="#0f9d58" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblGreen" Text="Green" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Purple -->
                        <Border x:Name="colorPurple" Style="{StaticResource AccentColorCardStyle}" Margin="0,0,0,10" MouseDown="ColorPurple_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="18" Height="18" Fill="#8e24aa" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblPurple" Text="Purple" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Pink -->
                        <Border x:Name="colorPink" Style="{StaticResource AccentColorCardStyle}" Margin="0,0,8,0" MouseDown="ColorPink_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="18" Height="18" Fill="#d81b60" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblPink" Text="Pink" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Cyan -->
                        <Border x:Name="colorCyan" Style="{StaticResource AccentColorCardStyle}" Margin="0,0,8,0" MouseDown="ColorCyan_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="18" Height="18" Fill="#00acc1" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblCyan" Text="Cyan" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Red -->
                        <Border x:Name="colorRed" Style="{StaticResource AccentColorCardStyle}" Margin="0,0,8,0" MouseDown="ColorRed_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="18" Height="18" Fill="#c62828" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblRed" Text="Red" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Indigo -->
                        <Border x:Name="colorIndigo" Style="{StaticResource AccentColorCardStyle}" Margin="0,0,0,0" MouseDown="ColorIndigo_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="18" Height="18" Fill="#3949ab" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblIndigo" Text="Indigo" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- 3. LIVE PREVIEW CARD -->
            <Border Grid.Row="2" Background="{DynamicResource ThemePanelBg}" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1" CornerRadius="12" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Preview" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <!-- Outer container of mockup, styles change based on Dark/Light -->
                    <Border x:Name="previewOuterContainer" Background="{DynamicResource ThemeBg}" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1" CornerRadius="10" Padding="25">
                        <StackPanel>
                            <!-- Mockup dashboard header -->
                            <Grid Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock x:Name="previewHeaderTitle" Text="Sample Card" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock x:Name="previewHeaderDesc" Text="This is how your dashboard will look" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="12" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Mockup primary action button -->
                                <Button x:Name="previewActionButton" Content="Action Button" Height="36" Padding="22,0" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="btnBorder" CornerRadius="18" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="13"/>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <!-- Three summary cards -->
                            <UniformGrid Columns="3">
                                <!-- Card 1 -->
                                <Border x:Name="previewCard1" Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="15" Margin="0,0,10,0" Height="90" BorderThickness="1" BorderBrush="{DynamicResource ThemeCardBorder}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="previewCardTitle1" Text="Total" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="Medium"/>
                                        <TextBlock x:Name="previewCardValue1" Text="1,247" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <!-- Card 2 -->
                                <Border x:Name="previewCard2" Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="15" Margin="0,0,10,0" Height="90" BorderThickness="1" BorderBrush="{DynamicResource ThemeCardBorder}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="previewCardTitle2" Text="Revenue" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="Medium"/>
                                        <TextBlock x:Name="previewCardValue2" Text="₱3,842" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <!-- Card 3 -->
                                <Border x:Name="previewCard3" Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="15" Margin="0,0,0,0" Height="90" BorderThickness="1" BorderBrush="{DynamicResource ThemeCardBorder}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="previewCardTitle3" Text="Active" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="Medium"/>
                                        <TextBlock x:Name="previewCardValue3" Text="89" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 4. FOOTER BUTTONS -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
                <Button Content="Cancel" Width="100" Height="36" Cursor="Hand" Click="Cancel_Click" Margin="0,0,15,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{DynamicResource ThemeNavBtnBg}" BorderThickness="1" BorderBrush="{DynamicResource ThemeCardBorder}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="{DynamicResource ThemeFgPrimary}"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeFgPrimary}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="btnSave" Content="Save Changes" Width="140" Height="36" Cursor="Hand" Click="Save_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnSaveBorder" CornerRadius="8" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource AppAccentButtonBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- 5. WARNING NOTES ALERT BAR -->
            <Border Grid.Row="4" Background="{DynamicResource ThemeNoteAlertBg}" CornerRadius="8" Padding="15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ⓘ" Foreground="{DynamicResource ThemeNoteAlertIconFg}" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12" LineHeight="18">
                        <Run Text="Note:" Foreground="{DynamicResource ThemeNoteAlertIconFg}" FontWeight="Bold"/>
                        <Run Text=" Theme, button style, and color changes will be applied after clicking &quot;Save Changes&quot;. The settings will persist across all sessions." Foreground="{DynamicResource ThemeNoteAlertFg}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
