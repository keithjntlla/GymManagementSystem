<UserControl x:Class="GymManagementSystem.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Dashboard Overview" Foreground="White" FontSize="30" FontWeight="Bold"/>
        <TextBlock Text="Welcome back! Here's what's happening today." Foreground="Gray" Margin="0,5,0,30"/>

        <UniformGrid Columns="3">
            <Border Background="#1a2b4d" CornerRadius="20" Height="200" Margin="0,0,20,0" Padding="25">
                <StackPanel>
                    <TextBlock Text="👥" FontSize="30" Foreground="#4a90e2"/>
                    <TextBlock Text="Total Active Members" Foreground="#888" Margin="0,20,0,5" FontSize="16"/>
                    <TextBlock x:Name="lblTotalMembers" Text="0" Foreground="White" FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#143d26" CornerRadius="20" Height="200" Margin="0,0,20,0" Padding="25">
                <StackPanel>
                    <TextBlock Text="💰" FontSize="30" Foreground="#4caf50"/>
                    <TextBlock Text="Today's Total Revenue" Foreground="#888" Margin="0,20,0,5" FontSize="16"/>
                    <TextBlock x:Name="lblTodayRevenue" Text="₱0.00" Foreground="White" FontSize="36" FontWeight="Bold"/>
                </StackPanel>   
            </Border>

            <Border Background="#3d2614" CornerRadius="20" Height="200" Padding="25">
                <StackPanel>
                    <TextBlock Text="🕒" FontSize="30" Foreground="#ff9800"/>
                    <TextBlock Text="Subscriptions Expiring (3 Days)" Foreground="#888" Margin="0,20,0,5" FontSize="16"/>
                    <TextBlock x:Name="lblExpiringSubscriptions" Text="0" Foreground="White" FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </StackPanel>
</UserControl>
