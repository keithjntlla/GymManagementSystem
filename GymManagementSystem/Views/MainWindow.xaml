<Window x:Class="GymManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gym Management System" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#1a191b">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                            CornerRadius="10" Margin="10,2">
                            <StackPanel Orientation="Horizontal" Margin="15,0">
                                <TextBlock x:Name="icon" Text="" FontFamily="Segoe UI Symbol" 
                                       VerticalAlignment="Center" Margin="0,0,15,0" FontSize="18"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="Home">
                                <Setter TargetName="icon" Property="Text" Value=""/>
                            </Trigger>
                            <Trigger Property="Content" Value="Members">
                                <Setter TargetName="icon" Property="Text" Value=""/>
                            </Trigger>
                            <Trigger Property="Content" Value="Instructors">
                                <Setter TargetName="icon" Property="Text" Value=""/>
                            </Trigger>
                            <Trigger Property="Content" Value="Payments">
                                <Setter TargetName="icon" Property="Text" Value="&#xE193;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Attendance">
                                <Setter TargetName="icon" Property="Text" Value=""/>
                            </Trigger>
                            <Trigger Property="Content" Value="Reports">
                                <Setter TargetName="icon" Property="Text" Value=""/>
                            </Trigger>
                            <Trigger Property="Content" Value="Settings">
                                <Setter TargetName="icon" Property="Text" Value=""/>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#ff6b00" Offset="0"/>
                                            <GradientStop Color="#ff0000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#141416" BorderBrush="#222" BorderThickness="0,0,1,0">
            <Grid>
                <StackPanel Margin="10,20">
                    <StackPanel Orientation="Horizontal" Margin="15,0,0,40">
                        <Image Source="C:\Users\Keith\Desktop\Organized_GymManagementSystem_Fixed\GymManagementSystem\Assets\logo.png" Width="30" Height="30" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Gym Dashboard" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <RadioButton Content="Home" IsChecked="True" Style="{StaticResource MenuButtonStyle}" Click="NavHome_Click"/>
                    <RadioButton Content="Members" Style="{StaticResource MenuButtonStyle}" Click="NavMembers_Click"/>

                    <RadioButton Content="Payments" Style="{StaticResource MenuButtonStyle}" Click="NavPayments_Click"/>
                    <RadioButton Content="Attendance" Style="{StaticResource MenuButtonStyle}" Click="NavAttendance_Click"/>

                    <Separator Background="#222" Margin="15,20"/>

                    <RadioButton Content="Reports" Style="{StaticResource MenuButtonStyle}" Click="NavReports_Click"/>
                    <RadioButton Content="Settings" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>

                <Button VerticalAlignment="Bottom" Margin="20,0,20,30" Background="Transparent" BorderThickness="0" Click="Logout_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="" FontFamily="Segoe UI Symbol" Foreground="#ff6b6b" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="LOG OUT" Foreground="#ff6b6b" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#1a191b">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="30"/>
        </Grid>
    </Grid>
</Window>
