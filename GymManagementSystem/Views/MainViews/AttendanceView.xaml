<UserControl x:Class="GymManagementSystem.Views.MainViews.AttendanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1000">

    <Grid Margin="0,20,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab Selection Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <RadioButton x:Name="tabMembers" Content="Member Attendance" Tag="👤" IsChecked="True" Style="{StaticResource TabButtonStyle}" Click="TabMembers_Click"/>
            <RadioButton x:Name="tabInstructors" Content="Instructor Attendance" Tag="🏋️" Style="{StaticResource TabButtonStyle}" Click="TabInstructors_Click"/>
        </StackPanel>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            
            <!-- MEMBER ATTENDANCE TAB PANEL -->
            <Grid x:Name="gridMembers" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.4*"/>
                    <ColumnDefinition Width="0.6*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#141416" CornerRadius="15" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <Border Background="#2a1a1a" CornerRadius="15" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <StackPanel>
                                    <TextBlock x:Name="lblLiveDate" Text="Day, MM DD, YY" Foreground="Gray" FontSize="16"/>
                                    <TextBlock x:Name="lblLiveTime" Text="00:00 PM" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#1a1212" CornerRadius="10" Padding="10">
                                    <TextBlock Text="🕒" Foreground="#ff6b00" FontSize="24"/>
                                </Border>
                            </Grid>
                        </Border>

                        <TextBlock Text="Member Check-in" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,10">
                            <TextBox x:Name="txtMemberSearch" 
                                     Style="{StaticResource ModernTextBox}" 
                                     Height="50" FontSize="20" Padding="10,0" 
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Left"
                                     Tag="Enter Member ID or Name..." Text="" 
                                     GotFocus="TxtMemberSearch_GotFocus"
                                     LostFocus="TxtMemberSearch_LostFocus"
                                     KeyDown="TxtMemberSearch_KeyDown"
                                     TextChanged="TxtMemberSearch_TextChanged"/>

                            <Popup x:Name="popSearch" PlacementTarget="{Binding ElementName=txtMemberSearch}" 
                                   Placement="Bottom" StaysOpen="False" 
                                   Width="{Binding ElementName=txtMemberSearch, Path=ActualWidth}">
                                <Border Background="#222" BorderBrush="#333" BorderThickness="1" CornerRadius="0,0,10,10">
                                    <ListBox x:Name="lstSearchResults" Background="Transparent" BorderThickness="0" 
                                             Foreground="White" MaxHeight="200" 
                                             SelectionChanged="LstSearchResults_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="10,5">
                                                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text="{Binding MemberID}" Foreground="Gray" FontSize="12"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>

                        <TextBlock Text="Select a member from the list to preview details" 
                                   Foreground="Gray" FontSize="12" Margin="5,0,0,20"/>

                        <Border x:Name="brdMemberProfile" Background="#1a191b" CornerRadius="10" Padding="15" Visibility="Collapsed" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="80" Height="80" CornerRadius="40" Background="#333" Margin="0,0,15,0">
                                    <Image x:Name="imgProfilePicture" Stretch="UniformToFill">
                                        <Image.Clip>
                                            <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                        </Image.Clip>
                                    </Image>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="lblMemberName" Text="" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Membership: " Foreground="Gray" FontSize="14" VerticalAlignment="Center"/>
                                        <ContentControl x:Name="lblMembershipType" Content="" Style="{StaticResource MembershipPlanBadge}" Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="Days Remaining: " Foreground="Gray" FontSize="14"/>
                                        <TextBlock x:Name="lblDaysRemaining" Text="" Foreground="White" FontSize="14"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button x:Name="btnCheckIn"
                                Content="✓   Check In Member"
                                Visibility="Collapsed"
                                Margin="0,0,0,10" Height="50"
                                FontSize="16" FontWeight="Bold"
                                Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="btnCheckIn_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1e7a3a"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#25a34d"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Grid Margin="0,10,0,0">
                            <Border x:Name="panelNoMemberAttendance" Height="150" CornerRadius="10" Background="#333" Visibility="Visible">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="👤" FontSize="48" Foreground="#555" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Select a member first to check-in" Foreground="Gray" FontSize="16" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="brdStatusIndicator" Height="150" CornerRadius="10" Background="#333" Visibility="Collapsed">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="txtStatusIcon" Text="" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtStatusMessage" Text="" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#141416" CornerRadius="15" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,20">
                            <TextBlock Text="Today's Member Attendance" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblTotalMembers" Text="Total: 0 members" Foreground="Gray" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </DockPanel>

                        <DataGrid x:Name="dgAttendanceLog" 
                                  Style="{StaticResource ModernDataGrid}"
                                  RowHeaderWidth="0" 
                                  ItemsSource="{Binding TodayAttendance}">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1a1a1c"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.5*"/>

                                <DataGridTemplateColumn Header="Membership Plan" Width="1.5*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ContentControl Content="{Binding MembershipType}" Style="{StaticResource MembershipPlanBadge}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Time In" Binding="{Binding CheckInTime}" Width="1*"/>
                                <DataGridTextColumn Header="Time Out" Binding="{Binding CheckOutTime}" Width="1*"/>

                                <DataGridTemplateColumn Header="Actions" Width="1.2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="⏱ Time Out" Foreground="#ff6b00" Background="Transparent" 
                                                    BorderThickness="0" FontSize="12" Cursor="Hand" 
                                                    HorizontalAlignment="Left" Click="TimeOut_Click" 
                                                    CommandParameter="{Binding AttendanceID}" Padding="5,2">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- INSTRUCTOR ATTENDANCE TAB PANEL -->
            <Grid x:Name="gridInstructors" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.4*"/>
                    <ColumnDefinition Width="0.6*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#141416" CornerRadius="15" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <Border Background="#1a2540" CornerRadius="15" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <StackPanel>
                                    <TextBlock x:Name="lblLiveDateInst" Text="Day, MM DD, YY" Foreground="Gray" FontSize="16"/>
                                    <TextBlock x:Name="lblLiveTimeInst" Text="00:00 PM" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#1a1f33" CornerRadius="10" Padding="10">
                                    <TextBlock Text="🕒" Foreground="#4a90e2" FontSize="24"/>
                                </Border>
                            </Grid>
                        </Border>

                        <TextBlock Text="Instructor Clock-In" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,10">
                            <TextBox x:Name="txtInstructorSearch" 
                                     Style="{StaticResource ModernTextBox}" 
                                     Height="50" FontSize="20" Padding="10,0" 
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Left"
                                     Tag="Enter Instructor ID or Name..." Text="" 
                                     GotFocus="TxtInstructorSearch_GotFocus"
                                     LostFocus="TxtInstructorSearch_LostFocus"
                                     KeyDown="TxtInstructorSearch_KeyDown"
                                     TextChanged="TxtInstructorSearch_TextChanged"/>

                            <Popup x:Name="popInstructorSearch" PlacementTarget="{Binding ElementName=txtInstructorSearch}" 
                                   Placement="Bottom" StaysOpen="False" 
                                   Width="{Binding ElementName=txtInstructorSearch, Path=ActualWidth}">
                                <Border Background="#222" BorderBrush="#333" BorderThickness="1" CornerRadius="0,0,10,10">
                                    <ListBox x:Name="lstInstructorSearchResults" Background="Transparent" BorderThickness="0" 
                                             Foreground="White" MaxHeight="200" 
                                             SelectionChanged="LstInstructorSearchResults_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="10,5">
                                                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text="{Binding InstructorID}" Foreground="Gray" FontSize="12"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>

                        <TextBlock Text="Select an instructor from the list to preview details" 
                                   Foreground="Gray" FontSize="12" Margin="5,0,0,20"/>

                        <Border x:Name="brdInstructorProfile" Background="#1a191b" CornerRadius="10" Padding="15" Visibility="Collapsed" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="80" Height="80" CornerRadius="40" Background="#333" Margin="0,0,15,0">
                                    <Image x:Name="imgInstructorProfilePicture" Stretch="UniformToFill">
                                        <Image.Clip>
                                            <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                        </Image.Clip>
                                    </Image>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="lblInstructorName" Text="" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Specialization: " Foreground="Gray" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblInstructorSpec" Text="" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="Status: " Foreground="Gray" FontSize="14"/>
                                        <TextBlock x:Name="lblInstructorStatus" Text="" Foreground="White" FontSize="14"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button x:Name="btnInstructorCheckIn"
                                Content="✓   Clock In Instructor"
                                Visibility="Collapsed"
                                Margin="0,0,0,10" Height="50"
                                FontSize="16" FontWeight="Bold"
                                Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="btnInstructorCheckIn_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1e7a3a"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#25a34d"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Grid Margin="0,10,0,0">
                            <Border x:Name="panelNoInstructorAttendance" Height="150" CornerRadius="10" Background="#333" Visibility="Visible">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="👤" FontSize="48" Foreground="#555" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Select an instructor first to clock-in" Foreground="Gray" FontSize="16" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="brdInstructorStatusIndicator" Height="150" CornerRadius="10" Background="#333" Visibility="Collapsed">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="txtInstructorStatusIcon" Text="" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtInstructorStatusMessage" Text="" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#141416" CornerRadius="15" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,20">
                            <TextBlock Text="Today's Instructor Logs" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblTotalInstructors" Text="Total: 0 instructors" Foreground="Gray" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </DockPanel>

                        <DataGrid x:Name="dgInstructorAttendanceLog" 
                                  Style="{StaticResource ModernDataGrid}"
                                  RowHeaderWidth="0">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1a1a1c"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.5*"/>
                                <DataGridTextColumn Header="Specialization" Binding="{Binding Specialization}" Width="1.5*"/>
                                <DataGridTextColumn Header="Time In" Binding="{Binding CheckInTime}" Width="1*"/>
                                <DataGridTextColumn Header="Time Out" Binding="{Binding CheckOutTime}" Width="1*"/>

                                <DataGridTemplateColumn Header="Actions" Width="1.2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="⏱ Clock Out" Foreground="#ff6b00" Background="Transparent" 
                                                    BorderThickness="0" FontSize="12" Cursor="Hand" 
                                                    HorizontalAlignment="Left" Click="InstructorTimeOut_Click" 
                                                    CommandParameter="{Binding AttendanceID}" Padding="5,2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Unified Alert Overlay -->
        <Border x:Name="brdAlertOverlay" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#4CAF50" CornerRadius="10" 
                Padding="20" HorizontalAlignment="Center" VerticalAlignment="Top" 
                Margin="0,50,0,0" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="txtAlertIcon" Text="✓" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBlock x:Name="txtAlertMessage" Text="Check-in Successful!" Foreground="White" FontSize="24" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>