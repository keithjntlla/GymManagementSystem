<Window x:Class="GymManagementSystem.Views.Windows.AddInstructorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add/Edit Instructor" Height="680" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="ModernToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid SnapsToDevicePixels="True">
                            <!-- Background Track -->
                            <Border x:Name="Track" Background="#333333" CornerRadius="15" BorderBrush="#444444" BorderThickness="1">
                                <Grid>
                                    <TextBlock x:Name="txtActive" Text="ON" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0" Visibility="Collapsed"/>
                                    <TextBlock x:Name="txtInactive" Text="OFF" Foreground="#888888" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="Visible"/>
                                </Grid>
                            </Border>
                            <!-- Thumb Indicator -->
                            <Border x:Name="Thumb" Background="White" CornerRadius="13" Width="26" Height="26" HorizontalAlignment="Left" Margin="2,0,2,0" VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#00a651"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#00c860"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="txtActive" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="txtInactive" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#222222" CornerRadius="15" BorderBrush="#333333" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="lblTitle" Text="Add New Instructor" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="18" Click="Cancel_Click"/>
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                <StackPanel>
                    <!-- Names Grid -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="First Name" Foreground="White"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBox x:Name="txtFirstName" Style="{StaticResource ModernTextBox}"/>
                            <TextBlock x:Name="lblFirstNameError" Foreground="#FF4444" FontSize="11" Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                            <TextBlock Text="M.I." Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtMiddleInitial" Style="{StaticResource ModernTextBox}" MaxLength="1" HorizontalContentAlignment="Center"/>
                            <TextBlock x:Name="lblMiddleInitialError" Foreground="#FF4444" FontSize="11" Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="5,0,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Last Name" Foreground="White"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBox x:Name="txtLastName" Style="{StaticResource ModernTextBox}"/>
                            <TextBlock x:Name="lblLastNameError" Foreground="#FF4444" FontSize="11" Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- Phone Number -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Phone Number" Foreground="White"/>
                        <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBox x:Name="txtPhone" Style="{StaticResource ModernTextBox}" Tag="09XXXXXXXXX" MaxLength="11" Margin="0,0,0,5"/>
                    <TextBlock x:Name="lblPhoneError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Birthday & Gender Grid -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Birthday" Foreground="White"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <DatePicker x:Name="dpBirthday" 
                                        Style="{StaticResource ModernDatePicker}" 
                                        Tag="MM-DD-YYYY" 
                                        ToolTip="You can type the date directly using the MM-DD-YYYY format."
                                        Padding="10"/>
                            <TextBlock x:Name="lblBirthdayError" Foreground="#FF4444" FontSize="11" Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Gender" Foreground="White"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <ComboBox x:Name="cmbGender" Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem Content="Male" IsSelected="True"/>
                                <ComboBoxItem Content="Female"/>
                                <ComboBoxItem Content="Other"/>
                            </ComboBox>
                            <TextBlock x:Name="lblGenderError" Foreground="#FF4444" FontSize="11" Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- Specializations -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Specialization" Foreground="White"/>
                        <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                    </StackPanel>
                    <ComboBox x:Name="cmbSpecialization" Style="{StaticResource ModernComboBox}" Margin="0,0,0,5"/>
                    <TextBlock x:Name="lblSpecializationError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Status Toggle -->
                    <StackPanel Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Instructor Status" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <ToggleButton x:Name="tglStatus" Style="{StaticResource ModernToggleSwitch}" IsChecked="True"/>
                            <TextBlock x:Name="lblStatusText" Text="Active" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Photo Upload -->
                    <TextBlock Text="Photo" Foreground="White" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="80" Height="80" Background="#1a1a1a" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
                            <Image x:Name="imgPhoto" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <Button Content="↑ Upload Photo" Margin="15,0,0,0" Padding="15,8" Background="#1a1a1a" Foreground="White" BorderBrush="#333" Click="UploadPhoto_Click"/>
                            <TextBlock x:Name="lblPhotoError" Foreground="#FF4444" FontSize="11" Margin="15,5,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnSave" Content="Save" Grid.Column="0" Margin="0,0,10,0" Padding="0,12" Background="#00a651" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="Save_Click"/>
                <Button Content="Cancel" Grid.Column="1" Margin="10,0,0,0" Padding="0,12" Background="#1a1a1a" Foreground="White" BorderBrush="#333" Click="Cancel_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
