<Window x:Class="GymManagementSystem.Views.Windows.RefundReasonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Refund Reason" Height="420" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource ThemeBg}" WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1" CornerRadius="15" Background="{DynamicResource ThemeBg}">
        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="↩  Refund Request" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="lblSubtitle" Text="Please state the reason before processing."
                               Foreground="{DynamicResource ThemeFgSecondary}" FontSize="13" Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Content="✕" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="18"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="Cancel_Click"/>
            </Grid>

            <!-- Separator -->
            <Separator Grid.Row="1" Background="{DynamicResource ThemeSeparator}" Margin="0,0,0,20"/>

            <!-- Reason dropdown -->
            <StackPanel Grid.Row="2" Margin="0,0,0,18">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Reason " Foreground="{DynamicResource ThemeFgPrimary}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="*" Foreground="#EF4444" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
                <ComboBox x:Name="cbReason"
                          Height="42"
                          FontSize="14"
                          SelectionChanged="CbReason_SelectionChanged">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBox}"/>
                    </ComboBox.Style>
                    <ComboBoxItem Content="Select a reason..." IsEnabled="False" IsSelected="True"/>
                    <ComboBoxItem Content="Member Request"/>
                    <ComboBoxItem Content="Double Payment"/>
                    <ComboBoxItem Content="Plan Change"/>
                    <ComboBoxItem Content="Health Reason"/>
                    <ComboBoxItem Content="Service Complaint"/>
                    <ComboBoxItem Content="Billing Error"/>
                    <ComboBoxItem Content="Other"/>
                </ComboBox>
                <TextBlock x:Name="lblReasonError" Text="A reason is required to proceed."
                           Foreground="#EF4444" FontSize="12" Margin="0,6,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Notes field -->
            <StackPanel Grid.Row="3" Margin="0,0,0,6">
                <TextBlock Text="Additional Notes (optional)" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="14"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Background="{DynamicResource ThemeInputBg}" BorderBrush="{DynamicResource ThemeInputBorder}" BorderThickness="1" CornerRadius="8">
                    <TextBox x:Name="txtNotes"
                             Background="Transparent"
                             Foreground="{DynamicResource ThemeFgPrimary}"
                             CaretBrush="{DynamicResource ThemeFgPrimary}"
                             BorderThickness="0"
                             FontSize="13"
                             Padding="12,10"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="80"
                             VerticalScrollBarVisibility="Auto"
                             MaxLength="250"
                             VerticalContentAlignment="Top"/>
                </Border>
                <TextBlock Text="Max 250 characters" Foreground="{DynamicResource ThemeFgMuted}" FontSize="11"
                           HorizontalAlignment="Right" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Confirm / Cancel buttons -->
            <Grid Grid.Row="5" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancel"
                        Height="44" FontSize="14" FontWeight="SemiBold"
                        Background="{DynamicResource ThemeCardBg}" Foreground="{DynamicResource ThemeFgMuted}" BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeCardBorder}" Cursor="Hand"
                        Click="Cancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ThemeNavBtnHoverBg}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeFgPrimary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" x:Name="btnConfirm"
                        Height="44" FontSize="14" FontWeight="Bold"
                        Cursor="Hand" IsEnabled="False" Opacity="0.5"
                        Click="Confirm_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#ff6b00" Offset="0"/>
                                        <GradientStop Color="#ff0000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↩ " Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Confirm Refund" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
