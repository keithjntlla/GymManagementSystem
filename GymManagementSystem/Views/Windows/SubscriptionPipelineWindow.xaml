<Window x:Class="GymManagementSystem.Views.Windows.SubscriptionPipelineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Subscription Pipeline" Height="620" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1e1e20" WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="#333" BorderThickness="1" CornerRadius="15" Background="#1e1e20">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Subscription Pipeline" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    <TextBlock x:Name="lblMemberDetails" Text="Member Name (ID)" Foreground="Gray" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Content="✕" Foreground="Gray" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Close_Click"/>
            </Grid>

            <Border Grid.Row="1" Background="#11331e" BorderBrush="#1e4d2b" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="📅" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Currently Active Plan" Foreground="White" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="Member is using this plan now" Foreground="#2ecc71" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                    <UniformGrid Columns="3">
                        <StackPanel>
                            <TextBlock Text="Plan Type" Foreground="Gray" FontSize="11"/>
                            <TextBlock x:Name="lblActiveType" Text="-" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Started" Foreground="Gray" FontSize="11"/>
                            <TextBlock x:Name="lblActiveStart" Text="-" Foreground="White" FontSize="14" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Expires" Foreground="Gray" FontSize="11"/>
                            <TextBlock x:Name="lblActiveExpiry" Text="-" Foreground="White" FontSize="14" Margin="0,4,0,0"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="🕒" FontSize="16" Foreground="#ff9800" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblQueueTitle" Text="Queued Plans (0)" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icQueuedPlans">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#141416" BorderBrush="#252528" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#ff9800" CornerRadius="10" Width="20" Height="20" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding QueueNumber}" Foreground="Black" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding PlanName}" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                                    <TextBlock Text="Activates when current plan expires" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Button Content="🗑" Foreground="#ff3333" Background="Transparent" BorderThickness="0" FontSize="16" 
                                                    HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="Hand"
                                                    Click="RefundPlan_Click" CommandParameter="{Binding PaymentID}"/>
                                        </Grid>

                                        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Start Date" Foreground="Gray" FontSize="11"/>
                                                <TextBlock Text="{Binding StartDate, StringFormat='{}{0:yyyy-MM-dd}'}" Foreground="White" FontSize="13" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Expiry Date" Foreground="Gray" FontSize="11"/>
                                                <TextBlock Text="{Binding ExpiryDate, StringFormat='{}{0:yyyy-MM-dd}'}" Foreground="White" FontSize="13" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Duration" Foreground="Gray" FontSize="11"/>
                                                <TextBlock Text="{Binding DurationDescription}" Foreground="White" FontSize="13" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </UniformGrid>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="#4a90e2" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Paid in Advance - Waiting for activation" Foreground="#4a90e2" FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Button Grid.Row="3" x:Name="btnAddAdvance" Style="{StaticResource ModernGradientButton}" 
                    Height="45" Click="AddAdvancePlan_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💳" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Add Advance Plan Payment" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </Grid>
    </Border>
</Window>