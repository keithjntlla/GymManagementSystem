<Window x:Class="GymManagementSystem.Views.Windows.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit User Account" Height="620" Width="400" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="15" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <TextBlock x:Name="lblHeaderTitle" Text="Edit User Account" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

                <!-- Username -->
                <TextBlock Text="Username" Foreground="{DynamicResource ThemeFgMuted}" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBox}" Margin="0,0,0,5"/>
                <TextBlock x:Name="lblUsernameError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                <!-- Role -->
                <TextBlock Text="Role" Foreground="{DynamicResource ThemeFgMuted}" Margin="0,0,0,5"/>
                <ComboBox x:Name="cbRole" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15">
                    <ComboBoxItem Content="Staff" IsSelected="True"/>
                    <ComboBoxItem Content="Administrator"/>
                </ComboBox>

                <!-- Current Password Section (Only shown for self-editing) -->
                <StackPanel x:Name="secCurrentPassword" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Current Password" Foreground="{DynamicResource ThemeFgMuted}"/>
                        <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,5">
                        <PasswordBox x:Name="pbCurrentPassword" Height="40" Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeFgPrimary}" 
                                     BorderBrush="{DynamicResource ThemeInputBorder}" Padding="10,0,10,0" VerticalContentAlignment="Center"/>
                        <TextBox x:Name="txtCurrentPasswordVisible" Height="40" Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeFgPrimary}" 
                                 BorderBrush="{DynamicResource ThemeInputBorder}" Padding="10,0,10,0" VerticalContentAlignment="Center" Visibility="Collapsed"/>
                    </Grid>
                    <TextBlock x:Name="lblCurrentPasswordError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,15" Visibility="Collapsed" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- New Password -->
                <TextBlock Text="New Password (Leave blank to keep current)" Foreground="{DynamicResource ThemeFgMuted}" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,5">
                    <PasswordBox x:Name="pbNewPassword" Height="40" Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeFgPrimary}" 
                                 BorderBrush="{DynamicResource ThemeInputBorder}" Padding="10,0,10,0" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtNewPasswordVisible" Height="40" Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeFgPrimary}" 
                             BorderBrush="{DynamicResource ThemeInputBorder}" Padding="10,0,10,0" VerticalContentAlignment="Center" Visibility="Collapsed"/>
                </Grid>
                <TextBlock x:Name="lblNewPasswordError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                <!-- Confirm New Password -->
                <TextBlock Text="Confirm New Password" Foreground="{DynamicResource ThemeFgMuted}" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,5">
                    <PasswordBox x:Name="pbConfirmNewPassword" Height="40" Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeFgPrimary}" 
                                 BorderBrush="{DynamicResource ThemeInputBorder}" Padding="10,0,10,0" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtConfirmNewPasswordVisible" Height="40" Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeFgPrimary}" 
                              BorderBrush="{DynamicResource ThemeInputBorder}" Padding="10,0,10,0" VerticalContentAlignment="Center" Visibility="Collapsed"/>
                </Grid>
                <TextBlock x:Name="lblConfirmNewPasswordError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                <!-- Show Passwords Checkbox -->
                <CheckBox x:Name="chkShowPasswords" Content="Show Passwords" Foreground="{DynamicResource ThemeFgSecondary}" VerticalAlignment="Center" 
                          Margin="0,0,0,25" Checked="TogglePassword_Checked" Unchecked="TogglePassword_Unchecked"/>

                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Save Changes" Background="#008a3b" Foreground="White" FontWeight="Bold" 
                            Height="45" Margin="0,0,10,0" Click="btnSave_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Grid.Column="1" Content="Cancel" Background="{DynamicResource ThemeNavBtnBg}" Foreground="{DynamicResource ThemeFgPrimary}" 
                            Height="45" Click="btnCancel_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
