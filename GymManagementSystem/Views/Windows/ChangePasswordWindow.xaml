<Window x:Class="GymManagementSystem.Views.Windows.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password" 
        SizeToContent="WidthAndHeight"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Border Background="#1a191b" CornerRadius="25" BorderBrush="#333" BorderThickness="1" Margin="10">
        <!-- Added a small margin to the border so the shadow or glow isn't cut off -->
        <StackPanel Margin="40" Width="370">
            <!-- Set a fixed Width here to control how wide the "small" window is -->

            <TextBlock Text="Change Password" Foreground="White" FontSize="28"
                       FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock Text="For your security, please set a new password before continuing"
                       Foreground="#999" FontSize="13" HorizontalAlignment="Center"
                       Margin="0,0,0,25" TextWrapping="Wrap" TextAlignment="Center"/>

            <!-- New Password -->
            <TextBlock Text="New Password" Foreground="#999" Margin="0,0,0,8" FontSize="15"/>
            <Grid Margin="0,0,0,5">
                <PasswordBox x:Name="pbNewPassword" Background="#222123" Foreground="White"
                             BorderBrush="#444" Padding="15,10" FontSize="15" CaretBrush="White"
                             MaxLength="64">
                    <PasswordBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
                <TextBox x:Name="txtNewVisible" Background="#222123" Foreground="White"
                         BorderBrush="#444" Padding="15,10" FontSize="15" CaretBrush="White"
                         MaxLength="64" Visibility="Collapsed">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Grid>
            <CheckBox x:Name="chkShowNew" Content="Show password" Foreground="#888"
                      FontSize="12" Margin="0,5,0,5"
                      Checked="chkShowNew_Checked" Unchecked="chkShowNew_Unchecked"/>
            <TextBlock x:Name="lblNewPasswordError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

            <!-- Confirm Password -->
            <TextBlock Text="Confirm New Password" Foreground="#999" Margin="0,0,0,8" FontSize="15"/>
            <Grid Margin="0,0,0,5">
                <PasswordBox x:Name="pbConfirm" Background="#222123" Foreground="White"
                             BorderBrush="#444" Padding="15,10" FontSize="15" CaretBrush="White"
                             MaxLength="64">
                    <PasswordBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
                <TextBox x:Name="txtConfirmVisible" Background="#222123" Foreground="White"
                          BorderBrush="#444" Padding="15,10" FontSize="15" CaretBrush="White"
                          MaxLength="64" Visibility="Collapsed">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Grid>
            <CheckBox x:Name="chkShowConfirm" Content="Show password" Foreground="#888"
                      FontSize="12" Margin="0,5,0,5"
                      Checked="chkShowConfirm_Checked" Unchecked="chkShowConfirm_Unchecked"/>
            <TextBlock x:Name="lblConfirmPasswordError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,15" Visibility="Collapsed" TextWrapping="Wrap"/>

            <Button x:Name="btnSave" Content="Save &amp; Continue" Height="50" FontSize="16"
                    FontWeight="Bold" Foreground="White" Click="btnSave_Click">
                <Button.Style>
                    <Style TargetType="{x:Type Button}">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#ff6b00" Offset="0"/>
                                    <GradientStop Color="#ff0000" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Border>
</Window>