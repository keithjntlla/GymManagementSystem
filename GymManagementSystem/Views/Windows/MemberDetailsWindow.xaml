<Window x:Class="GymManagementSystem.Views.Windows.MemberDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GymManagementSystem"
        Title="Member Profile Details" Height="700" Width="440"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <local:StringToCollectionConverter x:Key="StringToCollectionConverter"/>
        <local:PlanNameSplitterConverter x:Key="PlanSplitter"/>
    </Window.Resources>

    <Border Background="{DynamicResource ThemeCardBg}" Height="600" CornerRadius="15" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1" Margin="0,0,0,-74">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header / Close button -->
            <DockPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Member Profile" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="{DynamicResource ThemeFgSecondary}" BorderThickness="0" FontSize="18" Click="Close_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeFgPrimary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>

            <!-- Circular Avatar & Name Header -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Grid Width="110" Height="110" HorizontalAlignment="Center">
                    <!-- Initials Fallback (Dark Background) -->
                    <Border x:Name="brdInitials" Width="100" Height="100" CornerRadius="50" BorderThickness="2" Background="{DynamicResource ThemePanelBg}">
                        <TextBlock x:Name="txtInitials" Text="--" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- Perfect Circle Image -->
                    <Ellipse x:Name="ellPhoto" Width="100" Height="100" Stroke="#ff6b00" StrokeThickness="2" Visibility="Collapsed">
                        <Ellipse.Fill>
                            <ImageBrush x:Name="imgBrush" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>
                
                <TextBlock x:Name="txtFullName" Text="John Doe" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,2" TextAlignment="Center"/>
                <Border x:Name="brdStatusBadge" CornerRadius="12" Padding="12,4" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock x:Name="txtStatus" Text="ACTIVE" Foreground="White" FontSize="11" FontWeight="Bold"/>
                </Border>
            </StackPanel>

            <!-- Scrollable details grid -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                <StackPanel>
                    <!-- Grid of details -->
                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <!-- Column 1 & Column 2 details -->
                        <StackPanel Margin="0,0,10,15">
                            <TextBlock Text="MEMBER ID" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtMemberID" Text="--" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        
                        <StackPanel Margin="10,0,0,15">
                            <TextBlock Text="MEMBER TIER" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtMemberType" Text="Regular" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,10,15">
                            <TextBlock Text="PHONE NUMBER" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtPhone" Text="--" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Margin="10,0,0,15">
                            <TextBlock Text="GENDER" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtGender" Text="--" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,10,15">
                            <TextBlock Text="BIRTHDAY" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtBirthday" Text="--" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Margin="10,0,0,15">
                            <TextBlock Text="DATE JOINED" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtDateJoined" Text="--" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                    </UniformGrid>

                    <!-- Student ID Expiry (Only shown for Students) -->
                    <StackPanel x:Name="secStudentExpiry" Margin="0,5,0,15" Visibility="Collapsed">
                        <TextBlock Text="STUDENT ID EXPIRY DATE" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="txtStudentExpiry" Text="--" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border x:Name="brdStudentStatus" CornerRadius="8" Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="txtStudentStatus" Text="ACTIVE" Foreground="White" FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="{DynamicResource ThemePanelBg}" CornerRadius="10" Padding="15" Margin="0,5,0,0" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="MEMBERSHIP PLAN INFORMATION" Foreground="#00a651" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="CURRENT PLAN" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" Margin="0,0,0,6"/>
                                    <!-- Reused Badges Container -->
                                    <ItemsControl ItemsSource="{Binding MembershipPlan, Converter={StaticResource StringToCollectionConverter}}"
                                                  HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,4">
                                                    <ContentControl Content="{Binding Converter={StaticResource PlanSplitter}, ConverterParameter=0}" 
                                                                    Style="{StaticResource MembershipPlanBadge}" 
                                                                    VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="txtDaysRemaining" Text="--" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="12" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="EXPIRY DATE" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="txtExpiryDate" Text="--" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
