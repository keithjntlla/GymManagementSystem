<Window x:Class="GymManagementSystem.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gym Management System" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource ThemeBg}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Main sidebar nav button style -->
        <Style x:Key="MenuButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeSidebarFg}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="GroupName" Value="SidebarGroup"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                            CornerRadius="10" Margin="10,2">
                            <StackPanel Orientation="Horizontal" Margin="15,0">
                                <TextBlock x:Name="icon" Text="" FontFamily="Segoe UI Symbol" 
                                       VerticalAlignment="Center" Margin="0,0,15,0" FontSize="18"
                                       Foreground="{TemplateBinding Foreground}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="Home">
                                <Setter TargetName="icon" Property="Text" Value="🏠"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Members">
                                <Setter TargetName="icon" Property="Text" Value="👤"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Instructors">
                                <Setter TargetName="icon" Property="Text" Value="👥"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Payments">
                                <Setter TargetName="icon" Property="Text" Value="📝"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Attendance">
                                <Setter TargetName="icon" Property="Text" Value="💳"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Reports">
                                <Setter TargetName="icon" Property="Text" Value="✉️"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Settings">
                                <Setter TargetName="icon" Property="Text" Value="⚙️"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Services &amp; Pricing">
                                <Setter TargetName="icon" Property="Text" Value="💲"/>
                            </Trigger>
                            <Trigger Property="Content" Value="System">
                                <Setter TargetName="icon" Property="Text" Value="🖥️"/>
                            </Trigger>

                            <Trigger Property="Content" Value="Log Out">
                                <Setter TargetName="icon" Property="Text" Value="🚪"/>
                                <Setter Property="Foreground" Value="#ff6b6b"/>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AppAccentButtonBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeNavHoverBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeNavHoverFg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings toggle button (not a RadioButton so it doesn't join the group) -->
        <Style x:Key="SettingsToggleStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeSidebarFg}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="10" Margin="10,2">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                    <TextBlock Text="⚙️" FontFamily="Segoe UI Symbol"
                                               VerticalAlignment="Center" Margin="0,0,15,0" FontSize="18"
                                               Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Text="Settings" VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"
                                               FontWeight="{TemplateBinding FontWeight}"/>
                                </StackPanel>
                                <TextBlock x:Name="chevron" Text="›" FontSize="18"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,18,0"
                                           Foreground="{TemplateBinding Foreground}"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="chevronRotate" Angle="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeNavHoverBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeNavHoverFg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sub-menu item buttons -->
        <Style x:Key="SubMenuButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeSidebarFg}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="GroupName" Value="SidebarGroup"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="20,1,10,1">
                            <StackPanel Orientation="Horizontal" Margin="15,0">
                                <TextBlock x:Name="icon" Text="{TemplateBinding Tag}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15"
                                           Foreground="{TemplateBinding Foreground}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeSubNavActiveBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeNavHoverFg}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeSubNavHoverBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeNavHoverFg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource ThemeSidebarBg}" BorderBrush="{DynamicResource ThemeSidebarBorder}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top Header / Logo Section (Stacked) -->
                <StackPanel Grid.Row="0" Margin="25,25,25,20" HorizontalAlignment="Center">
                    <Image x:Name="imgSidebarLogo" 
                           Source="/Assets/logo.png" 
                           Width="75" 
                           Height="75" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"/>  

                    <TextBlock x:Name="txtSidebarGymName" 
                               Text="Gym Name" 
                               Foreground="{DynamicResource ThemeFgPrimary}" 
                               FontSize="25" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                        </StackPanel>

                <!-- Main Navigation Links -->
                <StackPanel Grid.Row="1" Margin="10,0">
                    <Separator Background="{DynamicResource ThemeSidebarBorder}" Margin="15,15"/>
                    <RadioButton Content="Home" IsChecked="True" Style="{StaticResource MenuButtonStyle}" Click="NavHome_Click"/>
                    <RadioButton x:Name="btnNavMembers" Content="Members" Style="{StaticResource MenuButtonStyle}" Click="NavMembers_Click"/>
                    <RadioButton x:Name="btnNavInstructors" Content="Instructors" Style="{StaticResource MenuButtonStyle}" Click="NavInstructors_Click"/>
                    <RadioButton x:Name="btnNavPayments" Content="Payments" Style="{StaticResource MenuButtonStyle}" Click="NavPayments_Click"/>
                    <RadioButton Content="Attendance" Style="{StaticResource MenuButtonStyle}" Click="NavAttendance_Click"/>
                </StackPanel>

                <!-- Footer Navigation Links &amp; Log Out -->
                <StackPanel Grid.Row="2" Margin="10,0,10,25">
                    <Separator Background="{DynamicResource ThemeSidebarBorder}" Margin="15,15"/>
                    <RadioButton x:Name="btnNavReports" Content="Reports" Style="{StaticResource MenuButtonStyle}" Click="NavReports_Click"/>

                    <!-- Settings expandable section -->
                    <Button x:Name="btnSettingsToggle"
                            Style="{StaticResource SettingsToggleStyle}"
                            Click="NavSettingsToggle_Click"/>

                    <!-- Settings sub-menu (collapsed by default) -->
                    <StackPanel x:Name="SettingsSubMenu" Visibility="Collapsed">
                        <RadioButton x:Name="btnNavServicesAndPricing"
                                     Content="Services &amp; Pricing"
                                     Style="{StaticResource MenuButtonStyle}"
                                     Click="NavServicesPricing_Click"/>
                        <RadioButton x:Name="btnNavSystem"
                                     Content="System"
                                     Style="{StaticResource MenuButtonStyle}"
                                     Click="NavSystem_Click"/>
                    </StackPanel>

                    <RadioButton Content="Log Out" 
                                 Style="{StaticResource MenuButtonStyle}" 
                                 Click="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Background="{DynamicResource ThemeBg}">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="30"/>
        </Grid>
    </Grid>
</Window>