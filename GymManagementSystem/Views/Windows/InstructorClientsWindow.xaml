<Window x:Class="GymManagementSystem.Views.Windows.InstructorClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assigned Clients" Height="480" Width="390"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="15" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1">
        <Grid Margin="24,16,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Drag Handle -->
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content (List) -->
                <RowDefinition Height="Auto"/> <!-- Close Button -->
            </Grid.RowDefinitions>

            <!-- Top Drag Handle -->
            <Border Grid.Row="0" Width="40" Height="4" Background="{DynamicResource ThemeFgMuted}" CornerRadius="2" Margin="0,0,0,16" HorizontalAlignment="Center" Opacity="0.5"/>

            <!-- Header Row -->
            <DockPanel Grid.Row="1" Margin="0,0,0,16">
                <StackPanel Orientation="Vertical">
                    <TextBlock x:Name="lblTrainerName" Text="Instructor Clients" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Currently assigned gym members" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" Foreground="{DynamicResource ThemeFgSecondary}" BorderThickness="0" FontSize="18" Click="Close_Click" Cursor="Hand"/>
            </DockPanel>

            <!-- List Container Row -->
            <Border Grid.Row="2" Background="{DynamicResource ThemePanelBg}" CornerRadius="10" Padding="10">
                <Grid>
                    <TextBlock x:Name="lblNoClients" Text="No clients currently assigned to this instructor." 
                               Foreground="{DynamicResource ThemeFgSecondary}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center"/>
                    
                    <ListBox x:Name="lstClients" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource ThemeSeparator}" BorderThickness="0,0,0,1" Padding="5,8" HorizontalAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FullName}" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Phone}" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#0e291d" CornerRadius="6" Padding="6,2" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Expired">
                                                            <Setter Property="Background" Value="#2b0d0e"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Background" Value="#3a2010"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#81c784"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Expired">
                                                                <Setter Property="Foreground" Value="#e57373"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                <Setter Property="Foreground" Value="#ffb74d"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Close Button Row -->
            <Button Grid.Row="3" Content="Close" Margin="0,16,0,0" Padding="0,12" Background="{DynamicResource ThemeNavBtnBg}" Foreground="{DynamicResource ThemeFgPrimary}" BorderBrush="{DynamicResource ThemeNavBtnBorder}" Click="Close_Click" Cursor="Hand"/>
        </Grid>
    </Border>
</Window>
