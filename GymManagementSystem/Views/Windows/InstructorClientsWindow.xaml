<Window x:Class="GymManagementSystem.Views.Windows.InstructorClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assigned Clients" Height="450" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Border Background="#222222" CornerRadius="15" BorderBrush="#333333" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Vertical">
                    <TextBlock x:Name="lblTrainerName" Text="Instructor Clients" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Currently assigned gym members" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="18" Click="Close_Click"/>
            </DockPanel>

            <Border Grid.Row="1" Background="#141416" CornerRadius="10" Padding="10">
                <Grid>
                    <TextBlock x:Name="lblNoClients" Text="No clients currently assigned to this instructor." 
                               Foreground="Gray" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center"/>
                    
                    <ListBox x:Name="lstClients" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#222" BorderThickness="0,0,0,1" Padding="5,8" Width="300">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FullName}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Phone}" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#0e291d" CornerRadius="6" Padding="6,2" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Expired">
                                                            <Setter Property="Background" Value="#2b0d0e"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Background" Value="#3a2010"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#81c784"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Expired">
                                                                <Setter Property="Foreground" Value="#e57373"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                <Setter Property="Foreground" Value="#ffb74d"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Button Grid.Row="2" Content="Close" Margin="0,20,0,0" Padding="0,12" Background="#1a1a1a" Foreground="White" BorderBrush="#333" Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
