<Window x:Class="GymManagementSystem.Views.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="680" Width="450"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">

    <Border Background="{DynamicResource ThemeBg}" CornerRadius="25" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1">
        <StackPanel Margin="40">

            <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" 
                    Foreground="{DynamicResource ThemeFgSecondary}" BorderThickness="0" Click="Close_Click"/>

            <!-- Logo: set x:Name so code-behind can swap it with the gym's custom logo -->
            <Image x:Name="imgLogo"
                   Source="/Assets/logo.png" 
                   Width="100" Height="100" 
                   HorizontalAlignment="Center" 
                   Margin="0,10,0,10"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Gym name (big) -->
            <TextBlock x:Name="txtLoginTitle" 
                       Foreground="{DynamicResource ThemeFgPrimary}" FontSize="28" 
                       FontWeight="SemiBold" HorizontalAlignment="Center" 
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,0,0,6"/>

            <!-- "Staff Login" subtitle -->
            <TextBlock x:Name="txtLoginSubtitle" Text="Member Login" 
                       Foreground="{DynamicResource ThemeFgMuted}" FontSize="15" 
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Username" Foreground="{DynamicResource ThemeFgMuted}" Margin="0,0,0,8" FontSize="16"/>
            <Grid Margin="0,0,0,5">
                <TextBox x:Name="txtUsername" Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeFgPrimary}" 
                         BorderBrush="{DynamicResource ThemeInputBorder}" Padding="15,10" FontSize="16" 
                         CaretBrush="{DynamicResource ThemeFgPrimary}">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock IsHitTestVisible="False" Text="Enter your username" 
                           VerticalAlignment="Center" HorizontalAlignment="Left" 
                           Margin="15,0,0,0" Foreground="{DynamicResource ThemeFgMuted}" FontSize="16">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=txtUsername}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <TextBlock x:Name="lblUsernameError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

            <TextBlock Text="Password" Foreground="{DynamicResource ThemeFgMuted}" Margin="0,0,0,8" FontSize="16"/>
            <PasswordBox x:Name="txtPassword" Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeFgPrimary}" 
                         BorderBrush="{DynamicResource ThemeInputBorder}" Padding="15,10" FontSize="16" CaretBrush="{DynamicResource ThemeFgPrimary}" Margin="0,0,0,5">
                <PasswordBox.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </PasswordBox.Resources>
            </PasswordBox>
            <TextBlock x:Name="lblPasswordError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

            <TextBlock Text="Forgot password?" Foreground="{DynamicResource AppAccentBrush}" HorizontalAlignment="Right" 
                       Margin="0,15,0,30" Cursor="Hand" FontSize="14"
                       MouseLeftButtonUp="ForgotPassword_Click"/>

            <Button Style="{StaticResource ModernGradientButton}"
                    Height="55" FontSize="18" Width="368"
                    FontWeight="Bold" Foreground="White" BorderThickness="0"
                    HorizontalAlignment="Right"
                    Content="Sign In"
                    Click="btnSignIn_Click">
            </Button>

        </StackPanel>
    </Border>
</Window>
