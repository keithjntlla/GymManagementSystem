<Window x:Class="GymManagementSystem.Views.Windows.AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New User" Height="480" Width="400" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="#252525" CornerRadius="15" BorderBrush="#333" BorderThickness="1">
        <StackPanel Margin="30">
            <TextBlock Text="Add New User" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,25"/>

            <!-- Username -->
            <TextBlock Text="Username" Foreground="#AAA" Margin="0,0,0,5"/>
            <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBox}" Margin="0,0,0,5"/>
            <TextBlock x:Name="lblUsernameError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

            <!-- Password with Unhide Option -->
            <TextBlock Text="Password" Foreground="#AAA" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,5">
                <PasswordBox x:Name="pbPassword" Height="40" Background="#181818" Foreground="White" 
                             BorderBrush="#333" Padding="10,0,35,0" VerticalContentAlignment="Center"/>
                <TextBox x:Name="txtPasswordVisible" Height="40" Background="#181818" Foreground="White" 
                          BorderBrush="#333" Padding="10,0,35,0" VerticalContentAlignment="Center" Visibility="Collapsed"/>

                <CheckBox x:Name="chkShowPassword" Foreground="Gray" VerticalAlignment="Center" 
                          HorizontalAlignment="Right" Margin="0,0,10,0" Checked="TogglePassword_Checked" Unchecked="TogglePassword_Unchecked"/>
            </Grid>
            <TextBlock x:Name="lblPasswordError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,15" Visibility="Collapsed" TextWrapping="Wrap"/>

            <!-- Role -->
            <TextBlock Text="Role" Foreground="#AAA" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbRole" Style="{StaticResource ModernComboBox}" Margin="0,0,0,30">
                <ComboBoxItem Content="Staff" IsSelected="True"/>
                <ComboBoxItem Content="Administrator"/>
            </ComboBox>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Add User" Background="#008a3b" Foreground="White" FontWeight="Bold" 
                        Height="45" Margin="0,0,10,0" Click="btnAdd_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Grid.Column="1" Content="Cancel" Background="#333" Foreground="White" 
                        Height="45" Click="btnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>