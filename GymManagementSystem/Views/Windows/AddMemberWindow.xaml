<Window x:Class="GymManagementSystem.Views.Windows.AddMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Member" Height="680" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Border Background="#222222" CornerRadius="15" BorderBrush="#333333" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="lblTitle" Text="Add New Member" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="18" Click="Cancel_Click"/>
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="First Name" Foreground="White"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBox x:Name="txtFirstName" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                            <TextBlock Text="M.I." Foreground="White" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtMiddleInitial" Style="{StaticResource ModernTextBox}" MaxLength="2" HorizontalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="5,0,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Last Name" Foreground="White"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBox x:Name="txtLastName" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Phone Number" Foreground="White"/>
                        <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBox x:Name="txtPhone" Style="{StaticResource ModernTextBox}" Tag="09XXXXXXXXX" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Birthday" Foreground="White"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <DatePicker x:Name="dpBirthday" 
                                        Style="{StaticResource ModernDatePicker}" 
                                        Tag="DD/MM/YYYY" 
                                        ToolTip="You can type the date directly using the MM/DD/YYYY format." 
                                        Padding="10"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Gender" Foreground="White"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <ComboBox x:Name="cmbGender" Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem Content="Male" IsSelected="True"/>
                                <ComboBoxItem Content="Female"/>
                                <ComboBoxItem Content="Other"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Member Type" Foreground="White"/>
                        <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                    </StackPanel>
                    <ComboBox x:Name="cmbMemberType" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15">
                        <ComboBoxItem Content="Regular" IsSelected="True"/>
                        <ComboBoxItem Content="Student"/>
                        <ComboBoxItem Content="Senior"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Date Joined" Foreground="White"/>
                        <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                    </StackPanel>
                    <DatePicker x:Name="dpDateJoined" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,15" Padding="10" IsHitTestVisible="False" Focusable="False" Background="#1a1a1a">
                        <DatePicker.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>

                    <TextBlock Text="Photo" Foreground="White" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="80" Height="80" Background="#1a1a1a" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
                            <Image x:Name="imgPhoto" Stretch="UniformToFill"/>
                        </Border>
                        <Button Content="↑ Upload Photo" Margin="15,0,0,0" Padding="15,8" Background="#1a1a1a" Foreground="White" BorderBrush="#333" VerticalAlignment="Center" Click="UploadPhoto_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnRegister" Content="Register" Grid.Column="0" Margin="0,0,10,0" Padding="0,12" Background="#00a651" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="Register_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Cancel" Grid.Column="1" Margin="10,0,0,0" Padding="0,12" Background="#1a1a1a" Foreground="White" BorderBrush="#333" Click="Cancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>