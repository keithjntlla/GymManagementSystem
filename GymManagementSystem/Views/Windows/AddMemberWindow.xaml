<Window x:Class="GymManagementSystem.Views.Windows.AddMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Member" Height="580" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Border Background="#222222" CornerRadius="15" BorderBrush="#333333" BorderThickness="1">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform/>
                <SkewTransform AngleX="-0.249"/>
                <RotateTransform/>
                <TranslateTransform X="-1.196"/>
            </TransformGroup>
        </Border.RenderTransform>
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="lblTitle" Text="Add New Member" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="18" Click="Cancel_Click"/>
            </DockPanel>

            <!-- Form -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="Full Name" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFullName" Background="#1a1a1a" Foreground="White" BorderBrush="#333" Padding="10" Margin="0,0,0,15"/>

                <TextBlock Text="Phone Number" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="txtPhone" Background="#1a1a1a" Foreground="White" BorderBrush="#333" Padding="10" Margin="0,0,0,15"/>

                <TextBlock Text="Gender" Foreground="White" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbGender" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15">
                    <ComboBoxItem Content="Male" IsSelected="True"/>
                    <ComboBoxItem Content="Female"/>
                    <ComboBoxItem Content="Other"/>
                </ComboBox>

                <TextBlock Text="Date Joined" Foreground="White" Margin="0,0,0,5"/>
                <DatePicker x:Name="dpDateJoined" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,15"/>

                <TextBlock Text="Photo" Foreground="White" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <Border Width="80" Height="80" Background="#1a1a1a" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
                        <Image x:Name="imgPhoto" Stretch="UniformToFill"/>
                    </Border>
                    <Button Content="↑ Upload Photo" Margin="15,0,0,0" Padding="15,8" Background="#1a1a1a" Foreground="White" BorderBrush="#333" VerticalAlignment="Center" Click="UploadPhoto_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Footer Buttons -->
            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnRegister" Content="Register" Grid.Column="0" Margin="0,0,10,0" Padding="0,12" Background="#00a651" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="Register_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Cancel" Grid.Column="1" Margin="10,0,0,0" Padding="0,12" Background="#1a1a1a" Foreground="White" BorderBrush="#333" Click="Cancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
