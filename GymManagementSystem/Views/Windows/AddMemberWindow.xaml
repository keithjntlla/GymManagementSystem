<Window x:Class="GymManagementSystem.Views.Windows.AddMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Member" Height="680" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="15" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="lblTitle" Text="Add New Member" Foreground="{DynamicResource ThemeFgPrimary}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" Foreground="{DynamicResource ThemeFgSecondary}" BorderThickness="0" FontSize="18" Click="Cancel_Click"/>
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="First Name" Foreground="{DynamicResource ThemeFgPrimary}"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBox x:Name="txtFirstName" Style="{StaticResource ModernTextBox}"/>
                            <TextBlock x:Name="lblFirstNameError" Foreground="#FF4444" FontSize="11" Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                            <TextBlock Text="M.I." Foreground="{DynamicResource ThemeFgPrimary}" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtMiddleInitial" Style="{StaticResource ModernTextBox}" MaxLength="1" HorizontalContentAlignment="Center"/>
                            <TextBlock x:Name="lblMiddleInitialError" Foreground="#FF4444" FontSize="11" Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="5,0,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Last Name" Foreground="{DynamicResource ThemeFgPrimary}"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBox x:Name="txtLastName" Style="{StaticResource ModernTextBox}"/>
                            <TextBlock x:Name="lblLastNameError" Foreground="#FF4444" FontSize="11" Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Phone Number" Foreground="{DynamicResource ThemeFgPrimary}"/>
                        <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBox x:Name="txtPhone" Style="{StaticResource ModernTextBox}" Tag="09XXXXXXXXX" MaxLength="11" Margin="0,0,0,5"/>
                    <TextBlock x:Name="lblPhoneError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Birthday" Foreground="{DynamicResource ThemeFgPrimary}"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <DatePicker x:Name="dpBirthday" 
                                        Style="{StaticResource ModernDatePicker}" 
                                        Tag="MM-DD-YYYY" 
                                        ToolTip="You can type the date directly using the MM-DD-YYYY format."
                                        Padding="10"/>
                            <TextBlock x:Name="lblBirthdayError" Foreground="#FF4444" FontSize="11" Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Gender" Foreground="{DynamicResource ThemeFgPrimary}"/>
                                <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                            </StackPanel>
                            <ComboBox x:Name="cmbGender" Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem Content="Male" IsSelected="True"/>
                                <ComboBoxItem Content="Female"/>
                                <ComboBoxItem Content="Other"/>
                            </ComboBox>
                            <TextBlock x:Name="lblGenderError" Foreground="#FF4444" FontSize="11" Margin="0,3,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Member Type Tier" Foreground="{DynamicResource ThemeFgPrimary}"/>
                        <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                    </StackPanel>
                    <ComboBox x:Name="cmbMemberType" Style="{StaticResource ModernComboBox}" Margin="0,0,0,5" SelectionChanged="CmbMemberType_SelectionChanged"/>
                    <TextBlock x:Name="lblMemberTypeError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>



                    <!-- Student Verification Section -->
                    <StackPanel x:Name="secStudentVerification" Visibility="Collapsed" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Student ID Expiry Date" Foreground="{DynamicResource ThemeFgPrimary}"/>
                            <TextBlock Text=" *" Foreground="#FF4444" FontWeight="Bold"/>
                        </StackPanel>
                        <DatePicker x:Name="dpStudentExpiry" Style="{StaticResource ModernDatePicker}" Tag="MM-DD-YYYY" ToolTip="Input the student ID expiry date in MM-DD-YYYY format." Margin="0,0,0,5"/>
                        <TextBlock x:Name="lblStudentExpiryError" Foreground="#FF4444" FontSize="11" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                        <TextBlock Text="Student ID Verification Checklist" Foreground="{DynamicResource ThemeFgMuted}" FontSize="12" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <CheckBox x:Name="chkStudentIdPresented" Content="Student ID Card presented" Foreground="{DynamicResource ThemeFgSecondary}" Margin="0,0,0,5"/>
                    </StackPanel>

                    <TextBlock Text="Assigned Trainer (Optional)" Foreground="{DynamicResource ThemeFgPrimary}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbTrainer" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="320">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}" Foreground="{DynamicResource ThemeFgPrimary}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding Specialization}" Foreground="{DynamicResource ThemeFgSecondary}" FontSize="11" Margin="0,2,0,0" IsHitTestVisible="False"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{DynamicResource ThemePanelBg}" CornerRadius="5" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1">
                                        <TextBlock Text="{Binding ClientCountText}" Foreground="#ff6b00" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Photo" Foreground="{DynamicResource ThemeFgPrimary}" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="80" Height="80" Background="{DynamicResource ThemePanelBg}" CornerRadius="10" BorderBrush="{DynamicResource ThemeCardBorder}" BorderThickness="1">
                            <Image x:Name="imgPhoto" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <Button Content="↑ Upload Photo" Margin="15,0,0,0" Padding="15,8" Background="{DynamicResource ThemeNavBtnBg}" Foreground="{DynamicResource ThemeFgPrimary}" BorderBrush="{DynamicResource ThemeNavBtnBorder}" Click="UploadPhoto_Click"/>
                            <TextBlock x:Name="lblPhotoError" Foreground="#FF4444" FontSize="11" Margin="15,5,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnRegister" Content="Register" Grid.Column="0" Margin="0,0,10,0" Padding="0,12" Background="#00a651" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="Register_Click"/>
                <Button Content="Cancel" Grid.Column="1" Margin="10,0,0,0" Padding="0,12" Background="{DynamicResource ThemeNavBtnBg}" Foreground="{DynamicResource ThemeFgPrimary}" BorderBrush="{DynamicResource ThemeNavBtnBorder}" Click="Cancel_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>