<Window x:Class="GymManagementSystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Member Login" Height="600" Width="450"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">

    <Border Background="#1a191b" CornerRadius="25" BorderBrush="#333" BorderThickness="1">
        <StackPanel Margin="40">

            <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" 
                    Foreground="Gray" BorderThickness="0" Click="Close_Click"/>

            <Image Source="/Assets/logo.png" 
               Width="100" 
               Height="100" 
               HorizontalAlignment="Center" 
               Margin="0,10,0,10"
               RenderOptions.BitmapScalingMode="HighQuality"/>
            
            <TextBlock Text="Member Login" Foreground="White" FontSize="32" 
                       FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <TextBlock Text="Username" Foreground="#999" Margin="0,0,0,8" FontSize="16"/>
            <Grid Margin="0,0,0,20">
                <TextBox x:Name="txtUsername" Background="#222123" Foreground="White" 
                         BorderBrush="#444" Padding="15,10" FontSize="16" 
                         CaretBrush="White">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock IsHitTestVisible="False" Text="Enter your username" VerticalAlignment="Center" 
                           HorizontalAlignment="Left" Margin="15,0,0,0" Foreground="#555" FontSize="16">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=txtUsername}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <TextBlock Text="Password" Foreground="#999" Margin="0,0,0,8" FontSize="16"/>
            <PasswordBox x:Name="txtPassword" Background="#222123" Foreground="White" 
                         BorderBrush="#444" Padding="15,10" FontSize="16" CaretBrush="White">
                <PasswordBox.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </PasswordBox.Resources>
            </PasswordBox>

            <TextBlock Text="Forgot password?" Foreground="#ff6b00" HorizontalAlignment="Right" 
                       Margin="0,15,0,30" Cursor="Hand" FontSize="14"/>

            <Button x:Name="btnSignIn" Content="Sign In" Height="55" FontSize="18" 
                    FontWeight="Bold" Foreground="White" Click="btnSignIn_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#ff6b00" Offset="0"/>
                                    <GradientStop Color="#ff0000" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Border>
</Window>